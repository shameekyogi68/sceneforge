      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Fira+Sans:wght@300;400;500;600&family=Fira+Code:wght@400;500&display=swap');\n\n    :root {\n        --color-bg: #010B13;\n        --color-navy: #011F5B;\n        --color-indigo: #6F00FF;\n        --color-aqua: #00CCFF;\n        --font-heading: 'Space Grotesk', sans-serif;\n        --font-body: 'Fira Sans', sans-serif;\n        --font-mono: 'Fira Code', monospace;\n    }\n\n    body {\n        background-color: var(--color-bg);\n        color: #F8FAFC;\n        font-family: var(--font-body);\n        margin: 0;\n        overflow-x: clip;\n    }\n\n    /* Custom Scrollbar */\n    ::-webkit-scrollbar {\n        width: 3px;\n    }\n    ::-webkit-scrollbar-track {\n        background: rgba(255, 255, 255, 0.02);\n    }\n    ::-webkit-scrollbar-thumb {\n        background: var(--color-indigo);\n    }\n\n    .dark-spotlight {\n        background: radial-gradient(circle at 50% 0%, rgba(0, 204, 255, 0.12) 0%, transparent 70%),\n                    radial-gradient(circle at 0% 100%, rgba(111, 0, 255, 0.08) 0%, transparent 50%);\n    }\n\n    .glassmorphism {\n        border: 1px solid rgba(255, 255, 255, 0.1);\n        background: rgba(1, 11, 19, 0.4);\n        backdrop-filter: blur(16px);\n    }\n\n    .glassmorphism-dark {\n        border: 1px solid rgba(255, 255, 255, 0.12);\n        background: rgba(1, 11, 19, 0.85);\n        backdrop-filter: blur(24px);\n    }\n\n    .neon-border {\n        box-shadow: 0 0 15px rgba(0, 204, 255, 0.1), inset 0 0 5px rgba(0, 204, 255, 0.05);\n    }\n\n    .circuit-bg {\n        background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%236f00ff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4v-4H4v4H0v2h4v4h2v-4h4v-2H6zm30 0v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");\n    }\n\n    .scanline {\n        width: 100%;\n        height: 100px;\n        z-index: 10;\n        background: linear-gradient(0deg, rgba(0, 204, 255, 0) 0%, rgba(0, 204, 255, 0.04) 50%, rgba(0, 204, 255, 0) 100%);\n        opacity: 0.15;\n        position: absolute;\n        pointer-events: none;\n        animation: scan 8s linear infinite;\n    }\n\n    .noise {\n        position: fixed;\n        inset: 0;\n        z-index: 100;\n        background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n        opacity: 0.03;\n        pointer-events: none;\n    }\n\n    @keyframes scan {\n        from { top: -100px; }\n        to { top: 100%; }\n    }\n\n    .pulse-glow {\n        animation: pulse-glow 3s ease-in-out infinite;\n    }\n\n</style>\n\n<div class=\"fixed inset-0 z-[-1]\" data-kid=\"1\">\n    <img src=\"https://images.pexels.com/photos/34742154/pexels-photo-34742154.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" class=\"w-full h-full object-cover opacity-10 grayscale brightness-50\" alt=\"Background\" decoding=\"async\" loading=\"lazy\" data-kid=\"2\">\n    <div class=\"absolute inset-0 dark-spotlight bg-[#010B13]/90\" data-kid=\"3\"></div>\n    <div class=\"absolute inset-0 circuit-bg opacity-30\" data-kid=\"4\"></div>\n    <div class=\"scanline\" data-kid=\"5\"></div>\n    <div class=\"noise\" data-kid=\"6\"></div>\n</div>\n\n<div class=\"flex flex-col h-screen w-full max-w-[375px] mx-auto overflow-hidden relative border-x border-white/5\" data-kid=\"7\">\n    \n    \n    <header class=\"pt-10 px-6 pb-6 flex items-center justify-between relative z-20\" data-kid=\"8\">\n        <div class=\"flex flex-col\" data-kid=\"9\">\n            <h1 class=\"font-['Space_Grotesk'] text-2xl font-bold tracking-tighter\" data-kid=\"10\">Script<span class=\"text-[#6F00FF]\" data-kid=\"11\">IQ</span></h1>\n            <div class=\"flex items-center gap-2 mt-0.5\" data-kid=\"12\">\n                <div class=\"w-1.5 h-1.5 rounded-full bg-[#00CCFF] shadow-[0_0_8px_#00CCFF]\" data-kid=\"13\"></div>\n                <span class=\"text-[10px] font-mono text-white/40 uppercase tracking-widest\" data-kid=\"14\">v4.2 // ONLINE</span>\n            </div>\n        </div>\n        <div class=\"flex items-center gap-4\" data-kid=\"15\">\n            <div class=\"text-right\" data-kid=\"16\">\n                <p class=\"text-[10px] font-mono text-white/30 uppercase tracking-tighter\" data-kid=\"17\">Director_ID</p>\n                <p class=\"text-[11px] font-mono text-white font-medium\" data-kid=\"18\">S_KYOGI_7</p>\n            </div>\n            <div class=\"w-11 h-11 rounded-2xl border border-white/10 p-0.5 overflow-hidden ring-1 ring-[#6F00FF]/30\" data-kid=\"19\">\n                <img src=\"https://i.pravatar.cc/100?u=director\" alt=\"Avatar\" class=\"w-full h-full rounded-2xl object-cover\" data-kid=\"20\">\n            </div>\n        </div>\n    </header>\n\n    \n    <div class=\"px-6 mb-6\" data-kid=\"21\">\n        <div class=\"relative group\" data-kid=\"22\">\n            <div class=\"absolute -inset-[1px] bg-gradient-to-r from-[#6F00FF]/40 to-[#00CCFF]/40 rounded-lg blur-[1px] opacity-20 group-focus-within:opacity-100 transition-opacity\" data-kid=\"23\"></div>\n            <div class=\"relative bg-white/5 border border-white/10 rounded-lg flex items-center px-4 py-2.5\" data-kid=\"24\">\n                <i data-lucide=\"search\" class=\"w-4 h-4 text-white/40 mr-3\" data-kid=\"25\"></i>\n                <input type=\"text\" placeholder=\"QUERY_RECORDS...\" class=\"bg-transparent text-[13px] font-mono outline-hidden w-full placeholder:text-white/20 text-white\" data-kid=\"26\">\n                <i data-lucide=\"terminal\" class=\"w-3.5 h-3.5 text-[#00CCFF] ml-2\" data-kid=\"27\"></i>\n            </div>\n        </div>\n    </div>\n\n    \n    <main class=\"flex-1 overflow-y-auto px-6 pb-48 pt-2 custom-scrollbar\" id=\"main-scroll\" data-kid=\"28\">\n        \n        \n        <div class=\"mb-10 pl-4 border-l-2 border-[#00CCFF] shadow-[-4px_0_12px_rgba(0,204,255,0.2)] reveal\" data-kid=\"29\">\n            <p class=\"text-[10px] font-mono text-[#00CCFF] uppercase tracking-[0.3em] mb-1.5 font-bold\" data-kid=\"30\">System_Log :: 10.0.4.1</p>\n            <p class=\"text-[13px] text-white/80 leading-relaxed font-light\" data-kid=\"31\">\n                Director, 4 project nodes are active. <span class=\"text-[#00CCFF] font-medium\" data-kid=\"32\">Astra_Script</span> has 2 unread sync insights from local servers.\n            </p>\n        </div>\n\n        <div class=\"flex items-center justify-between mb-5\" data-kid=\"33\">\n            <h2 class=\"text-[11px] font-mono text-white/40 uppercase tracking-[0.4em]\" data-kid=\"34\">Active_Nodes</h2>\n            <div class=\"flex items-center gap-1.5\" data-kid=\"35\">\n                <span class=\"text-[10px] font-mono text-[#00CCFF]/60 uppercase tracking-widest\" data-kid=\"36\">Live_Sync</span>\n                <div class=\"w-1.5 h-1.5 rounded-full bg-[#00CCFF] animate-pulse\" data-kid=\"37\"></div>\n            </div>\n        </div>\n\n        \n        <div class=\"space-y-6\" data-kid=\"38\">\n            \n            \n            <div class=\"project-card glassmorphism rounded-3xl p-6 relative overflow-hidden group cursor-pointer reveal\" data-kid=\"39\">\n                <div class=\"absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-20 transition-opacity\" data-kid=\"40\">\n                    <i data-lucide=\"zap\" class=\"w-16 h-16 text-[#6F00FF]\" data-kid=\"41\"></i>\n                </div>\n                <div class=\"flex justify-between items-start mb-5\" data-kid=\"42\">\n                    <div class=\"w-14 h-14 rounded-2xl bg-[#6F00FF]/15 border border-[#6F00FF]/30 flex items-center justify-center group-hover:bg-[#6F00FF]/25 transition-colors\" data-kid=\"43\">\n                        <i data-lucide=\"folder-kanban\" class=\"w-7 h-7 text-[#6F00FF]\" data-kid=\"44\"></i>\n                    </div>\n                    <div class=\"flex flex-col items-end\" data-kid=\"45\">\n                        <div class=\"px-2 py-0.5 bg-[#00CCFF]/10 border border-[#00CCFF]/40 rounded text-[9px] font-mono text-[#00CCFF] uppercase\" data-kid=\"46\">Critical_Priority</div>\n                    </div>\n                </div>\n                <h3 class=\"font-['Space_Grotesk'] font-bold text-xl tracking-tight mb-1.5 text-white group-hover:text-[#00CCFF] transition-colors\" data-kid=\"47\">Astra_Script</h3>\n                <p class=\"text-[12px] text-white/60 mb-5 font-light leading-relaxed\" data-kid=\"48\">Autonomous narrative synthesis for high-concept sci-fi feature film database.</p>\n                <div class=\"flex items-center justify-between border-t border-white/10 pt-5\" data-kid=\"49\">\n                    <div class=\"flex items-center gap-4 text-[10px] font-mono text-white/50\" data-kid=\"50\">\n                        <span class=\"flex items-center gap-2\" data-kid=\"51\"><i data-lucide=\"file-code\" class=\"w-3.5 h-3.5\" data-kid=\"52\"></i> 14_DOCS</span>\n                        <span class=\"flex items-center gap-2 text-[#00CCFF] font-bold\" data-kid=\"53\"><i data-lucide=\"activity\" class=\"w-3.5 h-3.5\" data-kid=\"54\"></i> SYNC_ACTIVE</span>\n                    </div>\n                    <div class=\"flex -space-x-2.5\" data-kid=\"55\">\n                        <img src=\"https://i.pravatar.cc/60?u=1\" class=\"w-7 h-7 rounded-full border border-[var(--color-bg)]\" alt=\"u1\" data-kid=\"56\">\n                        <img src=\"https://i.pravatar.cc/60?u=2\" class=\"w-7 h-7 rounded-full border border-[var(--color-bg)]\" alt=\"u2\" data-kid=\"57\">\n                        <div class=\"w-7 h-7 rounded-full bg-white/10 border border-white/20 flex items-center justify-center text-[8px] font-mono font-bold text-white/80\" data-kid=\"58\">+3</div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"space-y-3 pt-2\" data-kid=\"59\">\n                <div class=\"flex items-center justify-between group cursor-pointer reveal hover:bg-white/5 p-3 rounded-xl transition-colors\" data-kid=\"60\">\n                    <div class=\"flex items-center gap-4\" data-kid=\"61\">\n                        <div class=\"w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center group-hover:border-[#00CCFF]/40 transition-colors\" data-kid=\"62\">\n                            <i data-lucide=\"cpu\" class=\"w-5 h-5 text-white/40 group-hover:text-[#00CCFF]\" data-kid=\"63\"></i>\n                        </div>\n                        <div data-kid=\"64\">\n                            <h4 class=\"text-sm font-bold text-white/80 group-hover:text-white transition-colors\" data-kid=\"65\">Neon_Horizon</h4>\n                            <p class=\"text-[11px] text-white/40 font-mono tracking-tight uppercase mt-0.5\" data-kid=\"66\">Idle_Mode // 32 records</p>\n                        </div>\n                    </div>\n                    <i data-lucide=\"chevron-right\" class=\"w-4 h-4 text-white/20 group-hover:text-[#00CCFF]\" data-kid=\"67\"></i>\n                </div>\n\n                <div class=\"flex items-center justify-between group cursor-pointer reveal hover:bg-white/5 p-3 rounded-xl transition-colors\" data-kid=\"68\">\n                    <div class=\"flex items-center gap-4\" data-kid=\"69\">\n                        <div class=\"w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center group-hover:border-[#00CCFF]/40 transition-colors\" data-kid=\"70\">\n                            <i data-lucide=\"database\" class=\"w-5 h-5 text-white/40 group-hover:text-[#00CCFF]\" data-kid=\"71\"></i>\n                        </div>\n                        <div data-kid=\"72\">\n                            <h4 class=\"text-sm font-bold text-white/70 group-hover:text-white transition-colors\" data-kid=\"73\">Quantum_Void</h4>\n                            <p class=\"text-[11px] text-white/40 font-mono tracking-tight uppercase mt-0.5\" data-kid=\"74\">Archived // 156 records</p>\n                        </div>\n                    </div>\n                    <i data-lucide=\"chevron-right\" class=\"w-4 h-4 text-white/20 group-hover:text-[#00CCFF]\" data-kid=\"75\"></i>\n                </div>\n            </div>\n\n        </div>\n\n        \n        <div class=\"mt-12 mb-4 border-t border-white/5 pt-8 reveal\" data-kid=\"76\">\n            <h2 class=\"text-[11px] font-mono text-white/40 uppercase tracking-[0.4em] mb-6\" data-kid=\"77\">Director_Access_Metrics</h2>\n            <div class=\"flex flex-col gap-5\" data-kid=\"78\">\n                <div class=\"flex items-center justify-between\" data-kid=\"79\">\n                    <div class=\"flex items-center gap-3\" data-kid=\"80\">\n                        <div class=\"w-2 h-2 rounded-full bg-[#00CCFF]\" data-kid=\"81\"></div>\n                        <span class=\"text-[11px] font-mono text-white/60 uppercase\" data-kid=\"82\">System_Compute</span>\n                    </div>\n                    <span class=\"text-sm font-mono font-bold text-white\" data-kid=\"83\">84.2% <span class=\"text-[10px] text-white/30 font-normal\" data-kid=\"84\">USAGE</span></span>\n                </div>\n                <div class=\"h-1.5 w-full bg-white/5 rounded-full overflow-hidden border border-white/5\" data-kid=\"85\">\n                    <div class=\"h-full bg-gradient-to-r from-[#6F00FF] to-[#00CCFF] w-[84%] shadow-[0_0_10px_rgba(0,204,255,0.4)]\" data-kid=\"86\"></div>\n                </div>\n                \n                <div class=\"flex items-center justify-between\" data-kid=\"87\">\n                    <div class=\"flex items-center gap-3\" data-kid=\"88\">\n                        <div class=\"w-2 h-2 rounded-full bg-[#6F00FF]\" data-kid=\"89\"></div>\n                        <span class=\"text-[11px] font-mono text-white/60 uppercase\" data-kid=\"90\">Data_Transfer</span>\n                    </div>\n                    <span class=\"text-sm font-mono font-bold text-white\" data-kid=\"91\">0.8 <span class=\"text-[10px] text-white/30 font-normal\" data-kid=\"92\">GB/s</span></span>\n                </div>\n            </div>\n        </div>\n    </main>\n\n    \n    <nav class=\"fixed bottom-0 left-0 right-0 z-50 p-6 flex justify-center pointer-events-none\" data-kid=\"93\">\n        <div class=\"w-full max-w-[340px] glassmorphism-dark rounded-3xl px-1 py-2 flex items-center justify-between shadow-[0_-10px_40px_rgba(0,0,0,0.9)] border-white/10 pointer-events-auto relative\" data-kid=\"94\">\n            \n            <div class=\"flex-1 flex justify-around\" data-kid=\"95\">\n                <button class=\"nav-item p-3 text-[#00CCFF] bg-[#00CCFF]/10 rounded-2xl relative group\" data-kid=\"96\">\n                    <i data-lucide=\"layout-grid\" class=\"w-5 h-5\" data-kid=\"97\"></i>\n                    <div class=\"absolute -bottom-1 left-1/2 -translate-x-1/2 w-1.5 h-1.5 bg-[#00CCFF] rounded-full shadow-[0_0_8px_#00CCFF]\" data-kid=\"98\"></div>\n                </button>\n                <button class=\"nav-item p-3 text-white/40 hover:text-white transition-colors\" data-kid=\"99\">\n                    <i data-lucide=\"message-square\" class=\"w-5 h-5\" data-kid=\"100\"></i>\n                </button>\n            </div>\n\n            \n            <div class=\"relative w-20 flex justify-center\" data-kid=\"101\">\n                <button id=\"new-project-btn\" class=\"absolute -top-14 w-15 h-15 bg-[#6F00FF] rounded-2xl flex items-center justify-center shadow-[0_10px_30px_rgba(111,0,255,0.4)] border border-white/20 active:scale-90 transition-none\" data-kid=\"102\">\n                    <i data-lucide=\"plus\" class=\"w-8 h-8 text-white\" data-kid=\"103\"></i>\n                </button>\n            </div>\n\n            <div class=\"flex-1 flex justify-around\" data-kid=\"104\">\n                <button class=\"nav-item p-3 text-white/40 hover:text-white transition-colors\" data-kid=\"105\">\n                    <i data-lucide=\"zap\" class=\"w-5 h-5\" data-kid=\"106\"></i>\n                </button>\n                <button class=\"nav-item p-3 text-white/40 hover:text-white transition-colors\" data-kid=\"107\">\n                    <i data-lucide=\"settings\" class=\"w-5 h-5\" data-kid=\"108\"></i>\n                </button>\n            </div>\n\n            \n            <div class=\"absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-white/5 to-transparent rounded-b-2xl pointer-events-none\" data-kid=\"109\"></div>\n        </div>\n    </nav>\n\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"110\"></script>\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"111\"></script>\n<script type=\"module\" data-kid=\"112\">\n    import { animate } from 'https://esm.sh/animejs@4';\n\n    // Initialize Icons\n    lucide.createIcons();\n\n    // Entrance Animations\n    gsap.from(\"header\", {\n        y: -30,\n        opacity: 0,\n        duration: 0.8,\n        ease: \"power3.out\"\n    });\n\n    gsap.from(\".reveal\", {\n        y: 20,\n        opacity: 0,\n        duration: 0.8,\n        stagger: 0.15,\n        ease: \"power2.out\",\n        delay: 0.2\n    });\n\n    gsap.from(\"nav\", {\n        y: 50,\n        opacity: 0,\n        duration: 1,\n        ease: \"power4.out\",\n        delay: 0.5\n    });\n\n    // Hover/Interaction Animations\n    const cards = document.querySelectorAll('.project-card');\n    cards.forEach(card => {\n        card.addEventListener('mouseenter', () => {\n            gsap.to(card, {\n                y: -5,\n                borderColor: \"rgba(0, 204, 255, 0.3)\",\n                backgroundColor: \"rgba(255, 255, 255, 0.06)\",\n                duration: 0.3\n            });\n        });\n        card.addEventListener('mouseleave', () => {\n            gsap.to(card, {\n                y: 0,\n                borderColor: \"rgba(255, 255, 255, 0.08)\",\n                backgroundColor: \"rgba(255, 255, 255, 0.03)\",\n                duration: 0.3\n            });\n        });\n    });\n\n    const newBtn = document.getElementById('new-project-btn');\n    newBtn.addEventListener('mouseenter', () => {\n        animate(newBtn, {\n            scale: 1.1,\n            rotate: '90deg',\n            duration: 600,\n            easing: 'easeOutElastic(1, .8)'\n        });\n    });\n    newBtn.addEventListener('mouseleave', () => {\n        animate(newBtn, {\n            scale: 1,\n            rotate: '0deg',\n            duration: 400,\n            easing: 'easeOutQuad'\n        });\n    });\n\n    // Successive Scan Animation (Simulating data refresh)\n    const scanline = document.querySelector('.scanline');\n    setInterval(() => {\n        gsap.fromTo(scanline, \n            { top: \"-100px\" }, \n            { top: \"100%\", duration: 2, ease: \"none\" }\n        );\n    }, 10000);\n\n</script>\n",
