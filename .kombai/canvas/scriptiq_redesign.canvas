      "generation": {
        "prompt": "",
        "config": {}
      },
      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Fira+Sans:wght@300;400;500;600&family=Fira+Code:wght@400;500&display=swap');\n\n    :root {\n        --color-bg: #010B13;\n        --color-navy: #011F5B;\n        --color-indigo: #6F00FF;\n        --color-aqua: #00CCFF;\n        --font-heading: 'Space Grotesk', sans-serif;\n        --font-body: 'Fira Sans', sans-serif;\n        --font-mono: 'Fira Code', monospace;\n    }\n\n    .dark-spotlight {\n        background: radial-gradient(circle at 50% 0%, rgba(0, 204, 255, 0.15) 0%, transparent 70%),\n                    radial-gradient(circle at 0% 0%, rgba(111, 0, 255, 0.1) 0%, transparent 50%),\n                    linear-gradient(to bottom, transparent, rgba(1, 11, 19, 0.8));\n    }\n\n    .neon-inset {\n        border: 1px solid var(--color-aqua);\n        box-shadow: 0 0 15px rgba(0, 204, 255, 0.2), inset 0 0 10px rgba(0, 204, 255, 0.05);\n    }\n\n    .neon-tube {\n        position: absolute;\n        inset: -2px;\n        background: linear-gradient(90deg, var(--color-indigo), var(--color-aqua));\n        border-radius: inherit;\n        z-index: -1;\n        opacity: 0.15;\n        filter: blur(6px);\n    }\n\n    .glassmorphism {\n        border: 1px solid rgba(255, 255, 255, 0.12);\n        background: linear-gradient(135deg, rgba(255, 255, 255, 0.07) 0%, rgba(255, 255, 255, 0.03) 100%);\n        backdrop-filter: blur(40px);\n        box-shadow: 0 20px 80px rgba(0, 0, 0, 0.6), inset 0 0 0 1px rgba(255, 255, 255, 0.05);\n    }\n\n    .circuit-bg {\n        background-image: url(\"data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M10 10 L30 10 L30 30 M70 10 L90 10 L90 30 M10 90 L10 70 L30 70 M90 90 L70 90 L70 70' stroke='%2300CCFF' stroke-width='0.5' fill='none' opacity='0.2'/%3E%3Ccircle cx='30' cy='30' r='1.5' fill='%2300CCFF' opacity='0.2'/%3E%3Ccircle cx='70' cy='30' r='1.5' fill='%2300CCFF' opacity='0.2'/%3E%3Ccircle cx='30' cy='70' r='1.5' fill='%2300CCFF' opacity='0.2'/%3E%3Ccircle cx='70' cy='70' r='1.5' fill='%2300CCFF' opacity='0.2'/%3E%3C/svg%3E\");\n    }\n\n    .scanning-line {\n        position: absolute;\n        width: 100%;\n        height: 3px;\n        background: linear-gradient(90deg, transparent, rgba(0, 204, 255, 0.5), var(--color-aqua), rgba(0, 204, 255, 0.5), transparent);\n        top: 0;\n        left: 0;\n        opacity: 0;\n        z-index: 10;\n        filter: blur(1px);\n    }\n\n    @keyframes flicker {\n        0%, 19.999%, 22%, 62.999%, 64%, 64.999%, 70%, 100% { opacity: 1; }\n        20%, 21.999%, 63%, 63.999%, 65%, 69.999% { opacity: 0.4; }\n    }\n    .flicker-text {\n        animation: flicker 4s infinite;\n    }\n\n    .custom-input {\n        background: rgba(1, 31, 91, 0.5);\n        border: 1px solid rgba(255, 255, 255, 0.15);\n        color: white;\n    }\n    \n    .custom-input:focus {\n        border-color: var(--color-aqua);\n        box-shadow: 0 0 10px rgba(0, 204, 255, 0.1);\n        outline: none;\n    }\n\n    .drag-zone {\n        border: 2px dashed rgba(255, 255, 255, 0.1);\n        transition: all 0.3s ease;\n    }\n    \n    .drag-zone:hover {\n        border-color: var(--color-aqua);\n        background: rgba(0, 204, 255, 0.05);\n        box-shadow: 0 0 30px rgba(0, 204, 255, 0.05);\n    }\n\n    .btn-glow {\n        position: relative;\n        overflow: hidden;\n    }\n    \n    .btn-glow::after {\n        content: '';\n        position: absolute;\n        top: -50%;\n        left: -50%;\n        width: 200%;\n        height: 200%;\n        background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 70%);\n        opacity: 0;\n        transition: opacity 0.3s ease;\n    }\n    \n    .btn-glow:hover::after {\n        opacity: 1;\n    }\n\n    /* Override any default button transitions that might conflict with GSAP */\n    #create-btn {\n        transition: none !important;\n    }\n</style>\n\n<div class=\"min-h-screen w-full relative flex items-center justify-center bg-[#010B13] overflow-hidden font-['Fira_Sans']\" data-kid=\"1\">\n    \n    \n    <div class=\"absolute inset-0 z-0 opacity-40 blur-sm grayscale pointer-events-none\" data-kid=\"2\">\n        <div class=\"flex h-full w-full\" data-kid=\"3\">\n            <aside class=\"w-20 border-r border-white/5 flex flex-col items-center py-8 gap-10 bg-[#010B13]\" data-kid=\"4\"></aside>\n            <main class=\"flex-1 flex flex-col\" data-kid=\"5\">\n                <header class=\"h-20 border-b border-white/5\" data-kid=\"6\"></header>\n                <div class=\"flex-1 flex\" data-kid=\"7\">\n                    <div class=\"flex-[1.4] border-r border-white/5 bg-[#010B13]/40\" data-kid=\"8\"></div>\n                    <div class=\"flex-1 bg-[#011F5B]/20\" data-kid=\"9\"></div>\n                </div>\n            </main>\n        </div>\n        <div class=\"absolute inset-0 dark-spotlight\" data-kid=\"10\"></div>\n    </div>\n\n    \n    <div class=\"fixed inset-0 bg-black/60 backdrop-blur-md z-40 flex items-center justify-center p-6\" data-kid=\"11\">\n        \n        \n        <div id=\"modal\" class=\"glassmorphism w-full max-w-2xl rounded-3xl overflow-hidden relative\" data-kid=\"12\">\n            \n            <div class=\"absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-[#00CCFF]/40 to-transparent\" data-kid=\"13\"></div>\n            <div class=\"absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-[#6F00FF]/40 to-transparent\" data-kid=\"14\"></div>\n            \n            \n            <div class=\"h-10 bg-black/40 border-b border-white/5 flex items-center justify-between px-8\" data-kid=\"15\">\n                <div class=\"flex items-center gap-6\" data-kid=\"16\">\n                    <div class=\"flex items-center gap-2\" data-kid=\"17\">\n                        <div class=\"w-1.5 h-1.5 rounded-full bg-[#00CCFF] animate-pulse shadow-[0_0_6px_#00CCFF]\" data-kid=\"18\"></div>\n                        <span class=\"text-xs font-['Fira_Code'] text-white/60 uppercase tracking-widest flicker-text\" data-kid=\"19\">Terminal Active</span>\n                    </div>\n                    <span class=\"text-xs font-['Fira_Code'] text-[#00CCFF] uppercase tracking-tighter opacity-80\" data-kid=\"20\">Node: [astra_main_v4]</span>\n                </div>\n                <div class=\"flex items-center gap-4\" data-kid=\"21\">\n                    <span class=\"text-xs font-['Fira_Code'] text-white/20\" data-kid=\"22\">Protocol: SCR-IQ-091</span>\n                    <button class=\"text-white/30 hover:text-red-500 transition-colors\" data-kid=\"23\">\n                        <i data-lucide=\"power\" class=\"w-4 h-4\" data-kid=\"24\"></i>\n                    </button>\n                </div>\n            </div>\n\n            \n            <div class=\"p-8 pb-2 flex items-start justify-between\" data-kid=\"25\">\n                <div class=\"space-y-1\" data-kid=\"26\">\n                    <h1 class=\"text-4xl font-['Space_Grotesk'] font-bold text-white tracking-tighter\" data-kid=\"27\">Initialize New Research</h1>\n                    <p class=\"text-white/40 text-sm font-light\" data-kid=\"28\">Enter project parameters to start the deep-scan neural analysis sequence.</p>\n                </div>\n                <button class=\"p-3 rounded-xl hover:bg-white/5 text-white/20 hover:text-white transition-colors\" data-kid=\"29\">\n                    <i data-lucide=\"x\" class=\"w-6 h-6\" data-kid=\"30\"></i>\n                </button>\n            </div>\n\n            \n            <div class=\"px-8 py-4 space-y-6\" data-kid=\"31\">\n                \n                <div class=\"space-y-2\" data-kid=\"32\">\n                    <div class=\"flex justify-between items-center\" data-kid=\"33\">\n                        <label class=\"text-xs font-['Fira_Code'] text-[#00CCFF] font-bold uppercase tracking-widest\" data-kid=\"34\">Project Title</label>\n                        <span class=\"text-xs text-white/20 font-mono uppercase\" data-kid=\"35\">Reference: [AUTO_GEN]</span>\n                    </div>\n                    <div class=\"relative group\" data-kid=\"36\">\n                        <div class=\"neon-tube opacity-0 group-focus-within:opacity-100 transition-opacity\" data-kid=\"37\"></div>\n                        <input type=\"text\" placeholder=\"e.g. Project Astra\" class=\"custom-input w-full px-6 py-4 rounded-xl text-lg font-medium placeholder:text-white/30\" data-kid=\"38\">\n                    </div>\n                </div>\n\n                \n                <div class=\"space-y-3\" data-kid=\"39\">\n                    <label class=\"text-xs font-['Fira_Code'] text-[#00CCFF] font-bold uppercase tracking-widest\" data-kid=\"40\">Context Matrices / Genres</label>\n                    <div class=\"flex flex-wrap gap-2\" data-kid=\"41\">\n                        <button class=\"px-4 py-1.5 rounded-lg bg-[#00CCFF] text-[#010B13] text-[11px] font-bold uppercase tracking-tight shadow-[0_0_20px_rgba(0,204,255,0.4)] hover:brightness-110 transition-all\" data-kid=\"42\">Sci-Fi</button>\n                        <button class=\"px-4 py-1.5 rounded-lg bg-white/5 border border-white/15 text-white/60 text-[11px] font-bold uppercase tracking-tight hover:bg-[#00CCFF]/10 hover:border-[#00CCFF]/30 hover:text-white transition-all\" data-kid=\"43\">Thriller</button>\n                        <button class=\"px-4 py-1.5 rounded-lg bg-white/5 border border-white/15 text-white/60 text-[11px] font-bold uppercase tracking-tight hover:bg-[#00CCFF]/10 hover:border-[#00CCFF]/30 hover:text-white transition-all\" data-kid=\"44\">Noir</button>\n                        <button class=\"px-4 py-1.5 rounded-lg bg-white/5 border border-white/15 text-white/60 text-[11px] font-bold uppercase tracking-tight hover:bg-[#00CCFF]/10 hover:border-[#00CCFF]/30 hover:text-white transition-all\" data-kid=\"45\">Cyberpunk</button>\n                        <button class=\"px-3 py-1.5 rounded-lg border border-dashed border-white/20 text-white/20 text-[11px] font-bold uppercase hover:border-white/40 transition-colors flex items-center gap-1.5\" data-kid=\"46\">\n                            <i data-lucide=\"plus\" class=\"w-3 h-3\" data-kid=\"47\"></i> Add\n                        </button>\n                    </div>\n                </div>\n\n                \n                <div class=\"space-y-3\" data-kid=\"48\">\n                    <label class=\"text-xs font-['Fira_Code'] text-[#00CCFF] font-bold uppercase tracking-widest\" data-kid=\"49\">Document Ingest (.pdf)</label>\n                    <div class=\"drag-zone circuit-bg rounded-2xl p-8 flex flex-col items-center justify-center text-center group cursor-pointer relative overflow-hidden\" data-kid=\"50\">\n                        <div class=\"scanning-line\" data-kid=\"51\"></div>\n                        <div class=\"w-16 h-16 rounded-2xl bg-[#011F5B]/60 border border-white/10 flex items-center justify-center mb-4 group-hover:scale-105 group-hover:border-[#00CCFF]/60 transition-all duration-500 shadow-xl relative z-20\" data-kid=\"52\">\n                            <i data-lucide=\"cpu\" class=\"text-[#00CCFF] w-8 h-8 group-hover:animate-pulse\" data-kid=\"53\"></i>\n                        </div>\n                        <h3 class=\"text-white font-bold text-lg mb-1 relative z-20 tracking-tight\" data-kid=\"54\">Drop data-unit into matrix</h3>\n                        <p class=\"text-white/30 text-xs font-light relative z-20\" data-kid=\"55\">Click to link local filesystem or drag PDF. Max 50MB.</p>\n                        \n                        <div class=\"absolute top-0 left-0 w-6 h-6 border-t border-l border-[#00CCFF]/30 rounded-tl-lg group-hover:border-[#00CCFF] transition-colors\" data-kid=\"56\"></div>\n                        <div class=\"absolute bottom-0 right-0 w-6 h-6 border-b border-r border-[#00CCFF]/30 rounded-br-lg group-hover:border-[#00CCFF] transition-colors\" data-kid=\"57\"></div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"p-8 pt-4 flex items-center justify-between bg-black/20\" data-kid=\"58\">\n                <div class=\"flex flex-col\" data-kid=\"59\">\n                    <span class=\"text-[10px] font-['Fira_Code'] text-white/20 uppercase tracking-widest\" data-kid=\"60\">Security Clearance:</span>\n                    <span class=\"text-xs font-['Fira_Code'] text-green-500 uppercase font-bold tracking-tighter\" data-kid=\"61\">Authorized Lvl_3</span>\n                </div>\n                <div class=\"flex items-center gap-6\" data-kid=\"62\">\n                    <button class=\"text-white/30 hover:text-red-400 text-[10px] font-bold uppercase tracking-widest transition-colors\" data-kid=\"63\">\n                        Abort Initialization\n                    </button>\n                    <button id=\"create-btn\" class=\"neon-inset bg-[#00CCFF] text-[#010B13] px-10 py-3.5 rounded-xl font-bold uppercase tracking-[0.2em] text-sm flex items-center gap-3 active:scale-[0.95] btn-glow\" data-kid=\"64\">\n                        Initialize\n                        <i data-lucide=\"zap\" class=\"w-4 h-4 fill-current\" data-kid=\"65\"></i>\n                    </button>\n                </div>\n            </div>\n\n            \n            <div class=\"px-8 py-3 bg-[#010B13]/90 border-t border-white/5 flex items-center justify-between\" data-kid=\"66\">\n                <div class=\"flex items-center gap-4\" data-kid=\"67\">\n                    <span class=\"text-xs font-['Fira_Code'] text-white/30 uppercase tracking-widest\" data-kid=\"68\">Status: <span class=\"text-[#00CCFF]\" data-kid=\"69\">Syncing...</span></span>\n                    <div class=\"h-0.5 w-16 bg-white/5 rounded-full overflow-hidden\" data-kid=\"70\">\n                        <div class=\"h-full bg-gradient-to-r from-[#6F00FF] to-[#00CCFF] w-3/4 animate-[pulse_1.5s_infinite]\" data-kid=\"71\"></div>\n                    </div>\n                </div>\n                <span class=\"text-xs font-['Fira_Code'] text-white/20 uppercase tracking-widest\" data-kid=\"72\">v2.4.0-ASTRA_CORE</span>\n            </div>\n        </div>\n    </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"73\"></script>\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"74\"></script>\n<script data-kid=\"75\">\n    // Initialize Lucide Icons\n    lucide.createIcons();\n\n    // GSAP Modal Entrance Animation\n    window.addEventListener('load', () => {\n        const modal = document.getElementById('modal');\n        const overlay = modal.parentElement;\n        \n        // Ensure initial state for GSAP\n        // Constraint check: No opacity-0 on the element itself.\n        \n        gsap.set(overlay, { backgroundColor: 'rgba(0,0,0,0)' });\n        \n        const tl = gsap.timeline();\n        \n        tl.to(overlay, {\n            backgroundColor: 'rgba(0,0,0,0.7)',\n            duration: 1.2,\n            ease: 'power4.out'\n        })\n        .from(modal, {\n            y: 60,\n            opacity: 0,\n            scale: 0.98,\n            duration: 1.4,\n            ease: 'expo.out'\n        }, \"-=0.8\")\n        .from(\".space-y-8 > div\", {\n            y: 30,\n            opacity: 0,\n            stagger: 0.15,\n            duration: 1,\n            ease: 'power3.out'\n        }, \"-=1\");\n\n        // Scan Line Animation\n        const scanLine = document.querySelector('.scanning-line');\n        gsap.to(scanLine, {\n            top: '100%',\n            opacity: 1,\n            duration: 4,\n            repeat: -1,\n            ease: 'power1.inOut'\n        });\n    });\n\n    // Button Interaction\n    const createBtn = document.getElementById('create-btn');\n    createBtn.addEventListener('mouseenter', () => {\n        gsap.to(createBtn, {\n            boxShadow: '0 0 40px rgba(0, 204, 255, 0.8), inset 0 0 15px rgba(0, 204, 255, 0.2)',\n            scale: 1.02,\n            duration: 0.4,\n            ease: 'power2.out'\n        });\n    });\n    createBtn.addEventListener('mouseleave', () => {\n        gsap.to(createBtn, {\n            boxShadow: '0 0 15px rgba(0, 204, 255, 0.2), inset 0 0 10px rgba(0, 204, 255, 0.05)',\n            scale: 1,\n            duration: 0.4,\n            ease: 'power2.out'\n        });\n    });\n</script>\n",
