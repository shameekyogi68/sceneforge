      "html": "\n<section class=\"flex h-screen bg-[#100C08] text-[#e2e0da] font-serif overflow-hidden antialiased\" data-kid=\"0\">\n  \n  <aside class=\"w-80 bg-[#003153] border-r border-white/5 flex flex-col z-20 shadow-2xl\" data-kid=\"1\">\n    <div class=\"p-10\" data-kid=\"2\">\n      <h1 class=\"text-4xl font-['Playfair_Display'] text-[#D4AF37] tracking-tighter italic select-none\" data-kid=\"3\">ScriptIQ</h1>\n      <p class=\"text-[9px] uppercase tracking-[0.4em] text-[#D4AF37]/50 mt-2 font-sans\" data-kid=\"4\">Cinematic Intelligence</p>\n    </div>\n    \n    <nav class=\"flex-1 px-6 space-y-12\" data-kid=\"5\">\n      \n      <div data-kid=\"6\">\n        <h2 class=\"text-[10px] uppercase tracking-[0.25em] text-[#D4AF37] mb-6 px-4 font-sans opacity-60\" data-kid=\"7\">Active Script</h2>\n        <div class=\"bg-white/5 p-4 border border-[#D4AF37]/20 rounded-sm\" data-kid=\"8\">\n          <p class=\"text-sm font-['Playfair_Display'] italic text-[#D4AF37]\" data-kid=\"9\">The Silent Shore</p>\n          <p class=\"text-[10px] text-white/40 mt-1 font-sans\" data-kid=\"10\">Draft v.2.4 — Updated Today</p>\n        </div>\n      </div>\n\n      \n      <div data-kid=\"11\">\n        <h2 class=\"text-[10px] uppercase tracking-[0.25em] text-[#D4AF37] mb-6 px-4 font-sans opacity-60\" data-kid=\"12\">Research Library</h2>\n        <div class=\"space-y-2\" data-kid=\"13\">\n          <div class=\"group flex items-center justify-between p-4 rounded-sm bg-white/5 border border-transparent hover:border-[#D4AF37]/30 cursor-pointer transition-all\" data-kid=\"14\">\n            <div class=\"flex items-center gap-4\" data-kid=\"15\">\n              <div class=\"w-1.5 h-1.5 rounded-full bg-[#D4AF37] shadow-[0_0_8px_#D4AF37]\" data-kid=\"16\"></div>\n              <span class=\"text-xs font-['Source_Serif_4'] font-medium text-white/90\" data-kid=\"17\">Excerpt-1_DTPP.pdf</span>\n            </div>\n            <i class=\"ti ti-file-text text-white/20 group-hover:text-[#D4AF37]/50 transition-colors\" data-kid=\"18\"></i>\n          </div>\n          <div class=\"group flex items-center justify-between p-4 rounded-sm hover:bg-white/5 border border-transparent hover:border-white/10 cursor-pointer transition-all\" data-kid=\"19\">\n            <div class=\"flex items-center gap-4\" data-kid=\"20\">\n              <div class=\"w-1.5 h-1.5 rounded-full bg-white/20\" data-kid=\"21\"></div>\n              <span class=\"text-xs font-['Source_Serif_4'] text-white/50\" data-kid=\"22\">Character_Study_Final.pdf</span>\n            </div>\n            <i class=\"ti ti-file-text text-white/10\" data-kid=\"23\"></i>\n          </div>\n          <div class=\"group flex items-center justify-between p-4 rounded-sm hover:bg-white/5 border border-transparent hover:border-white/10 cursor-pointer transition-all opacity-60\" data-kid=\"24\">\n            <div class=\"flex items-center gap-4\" data-kid=\"25\">\n              <div class=\"w-1.5 h-1.5 rounded-full bg-white/20\" data-kid=\"26\"></div>\n              <span class=\"text-xs font-['Source_Serif_4'] text-white/50\" data-kid=\"27\">Historical_Context.pdf</span>\n            </div>\n            <i class=\"ti ti-file-text text-white/10\" data-kid=\"28\"></i>\n          </div>\n        </div>\n      </div>\n    </nav>\n    \n    \n    <div class=\"p-8 border-t border-white/5 bg-black/20\" data-kid=\"29\">\n      <div class=\"flex items-center gap-4\" data-kid=\"30\">\n        <div class=\"relative\" data-kid=\"31\">\n          <img src=\"https://i.pravatar.cc/100?u=screenwriter\" class=\"w-12 h-12 rounded-sm grayscale hover:grayscale-0 transition-all duration-700\" alt=\"Avatar\" data-kid=\"32\">\n          <div class=\"absolute -bottom-1 -right-1 w-3 h-3 bg-[#D4AF37] border-2 border-[#003153] rounded-full\" data-kid=\"33\"></div>\n        </div>\n        <div data-kid=\"34\">\n          <p class=\"text-xs font-bold text-white/90 font-sans tracking-wide\" data-kid=\"35\">ELARA VANCE</p>\n          <p class=\"text-[9px] text-[#D4AF37] uppercase tracking-widest font-sans font-medium\" data-kid=\"36\">Head of Narrative</p>\n        </div>\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 relative flex flex-col h-full bg-[#100C08]\" data-kid=\"37\">\n    \n    <div class=\"grain\" data-kid=\"38\"></div>\n    \n    <div class=\"absolute inset-0 z-0 overflow-hidden pointer-events-none\" data-kid=\"39\">\n      <video src=\"https://videos.pexels.com/video-files/31481035/13422642_640_360_25fps.mp4\" poster=\"https://images.pexels.com/videos/31481035/super-8-film-texture-overlay-8mm-31481035.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"w-full h-full object-cover opacity-[0.07]\" data-kid=\"40\"></video>\n      <div class=\"absolute inset-0 bg-gradient-to-b from-[#100C08] via-transparent to-[#100C08]\" data-kid=\"41\"></div>\n    </div>\n\n    \n    <header class=\"relative z-30 h-16 border-b border-white/5 flex items-center justify-between px-10 bg-[#100C08]/80 backdrop-blur-xl\" data-kid=\"42\">\n      <div class=\"flex items-center gap-6\" data-kid=\"43\">\n        <nav class=\"flex items-center gap-2 text-[10px] uppercase tracking-widest font-sans text-white/30\" data-kid=\"44\">\n          <span class=\"hover:text-[#D4AF37] cursor-pointer transition-colors\" data-kid=\"45\">Projects</span>\n          <i class=\"ti ti-chevron-right text-[8px]\" data-kid=\"46\"></i>\n          <span class=\"text-white/80\" data-kid=\"47\">The Silent Shore</span>\n        </nav>\n      </div>\n      <div class=\"flex items-center gap-6\" data-kid=\"48\">\n        <div class=\"flex items-center gap-3 px-4 py-1.5 border border-[#D4AF37]/30 rounded-full\" data-kid=\"49\">\n           <span class=\"text-[10px] text-[#D4AF37] font-sans\" data-kid=\"50\">98 QUERIES REMAINING</span>\n        </div>\n        <button class=\"text-white/40 hover:text-[#D4AF37] transition-colors\" data-kid=\"51\">\n          <i class=\"ti ti-settings text-lg\" data-kid=\"52\"></i>\n        </button>\n      </div>\n    </header>\n\n    \n    <div id=\"chat-scroller\" class=\"flex-1 overflow-y-auto relative z-10 scroll-smooth\" data-kid=\"53\">\n      <div class=\"max-w-4xl mx-auto py-24 px-12 space-y-24\" data-kid=\"54\">\n        \n        \n        <div class=\"chat-message user-query flex justify-end\" data-kid=\"55\">\n          <div class=\"max-w-[60%] text-right space-y-4\" data-kid=\"56\">\n            <div class=\"flex items-center justify-end gap-3 mb-2\" data-kid=\"57\">\n              <div class=\"h-[1px] w-8 bg-[#D4AF37]/30\" data-kid=\"58\"></div>\n              <span class=\"text-[10px] uppercase tracking-[0.4em] text-[#D4AF37] font-sans\" data-kid=\"59\">Inquiry 01</span>\n            </div>\n            <p class=\"text-2xl md:text-3xl font-['Playfair_Display'] italic text-white/95 leading-tight tracking-tight\" data-kid=\"60\">Summarize the key plot points of the first act.</p>\n          </div>\n        </div>\n\n        \n        <div class=\"chat-message ai-response opacity-0 translate-y-8 pb-32\" data-kid=\"61\">\n          <div class=\"flex items-start gap-8 md:gap-12\" data-kid=\"62\">\n            <div class=\"sticky top-24 shrink-0 w-14 h-14 flex items-center justify-center bg-[#003153] border border-[#D4AF37]/30 shadow-[0_0_25px_rgba(212,175,55,0.15)] rounded-sm\" data-kid=\"63\">\n              <i class=\"ti ti-camera-pin text-2xl text-[#D4AF37]\" data-kid=\"64\"></i>\n              <div class=\"absolute -top-1 -left-1 w-2 h-2 border-t border-l border-[#D4AF37]\" data-kid=\"65\"></div>\n              <div class=\"absolute -bottom-1 -right-1 w-2 h-2 border-b border-r border-[#D4AF37]\" data-kid=\"66\"></div>\n            </div>\n            \n            <article class=\"flex-1 space-y-16\" data-kid=\"67\">\n              <header class=\"flex items-center justify-between border-b border-white/10 pb-6\" data-kid=\"68\">\n                <div class=\"flex flex-col\" data-kid=\"69\">\n                  <span class=\"text-[10px] uppercase tracking-[0.5em] text-[#D4AF37] font-sans font-bold\" data-kid=\"70\">The Script Intelligence</span>\n                  <span class=\"text-[9px] uppercase tracking-[0.2em] text-white/30 mt-1 font-sans\" data-kid=\"71\">Revision 204 // Editorial Analysis</span>\n                </div>\n                <div class=\"text-right\" data-kid=\"72\">\n                  <span class=\"text-[10px] text-[#D4AF37] font-sans border border-[#D4AF37]/20 px-3 py-1 rounded-full uppercase tracking-widest\" data-kid=\"73\">Act I</span>\n                </div>\n              </header>\n\n              <div class=\"prose-container relative\" data-kid=\"74\">\n                \n                <p id=\"typing-target\" class=\"text-3xl md:text-4xl font-['Source_Serif_4'] leading-[1.2] first-letter:text-8xl md:first-letter:text-9xl first-letter:font-['Playfair_Display'] first-letter:float-left first-letter:mr-4 first-letter:text-[#D4AF37] first-letter:leading-[0.6] text-white/95 mb-12\" data-kid=\"75\">\n                  The narrative trajectory of the opening sequence is defined by a series of quiet, cinematic transitions that bridge the gap between past isolation and present tension.\n                </p>\n                \n                <div class=\"h-px w-full bg-gradient-to-r from-[#D4AF37]/40 via-transparent to-transparent mb-12\" data-kid=\"76\"></div>\n\n                <ul class=\"space-y-10 list-none p-0\" data-kid=\"77\">\n                  <li class=\"pl-12 border-l border-[#D4AF37]/30 relative group\" data-kid=\"78\">\n                    <div class=\"absolute left-0 top-3 w-4 h-[1px] bg-[#D4AF37]/50 -translate-x-full\" data-kid=\"79\"></div>\n                    <p class=\"text-xl font-['Source_Serif_4'] text-white/80 leading-relaxed italic\" data-kid=\"80\">\n                      Hardik, feeling restless and unsettled two years after his degree, is at a bus stand <span class=\"text-[11px] font-sans not-italic text-[#D4AF37] ml-2 tracking-widest\" data-kid=\"81\">[SOURCE 4]</span>.\n                    </p>\n                  </li>\n                  <li class=\"pl-10 border-l-[1px] border-[#D4AF37]/20 relative group\" data-kid=\"82\">\n                    <div class=\"absolute left-0 top-3 w-4 h-[1px] bg-[#D4AF37]/50 -translate-x-full\" data-kid=\"83\"></div>\n                    <p class=\"text-xl font-['Source_Serif_4'] text-white/80 leading-relaxed italic\" data-kid=\"84\">\n                      He hears a call for \"Bhatkal!\" which deeply affects him, and he runs to catch a bus displaying \"Kundapur – Byndoor – Bhatkal,\" feeling a \"familiar excitement\" and \"forgotten rush\" <span class=\"text-[11px] font-sans not-italic text-[#D4AF37] ml-2 tracking-widest\" data-kid=\"85\">[SOURCE 4]</span>.\n                    </p>\n                  </li>\n                  <li class=\"pl-10 border-l-[1px] border-[#D4AF37]/20 relative group\" data-kid=\"86\">\n                    <div class=\"absolute left-0 top-3 w-4 h-[1px] bg-[#D4AF37]/50 -translate-x-full\" data-kid=\"87\"></div>\n                    <p class=\"text-xl font-['Source_Serif_4'] text-white/80 leading-relaxed italic\" data-kid=\"88\">\n                      On the bus, Ishani is guarding a seat for him, preventing another woman from taking it <span class=\"text-[11px] font-sans not-italic text-[#D4AF37] ml-2 tracking-widest\" data-kid=\"89\">[SOURCE 5]</span>.\n                    </p>\n                  </li>\n                  <li class=\"pl-10 border-l-[1px] border-[#D4AF37]/20 relative group\" data-kid=\"90\">\n                    <div class=\"absolute left-0 top-3 w-4 h-[1px] bg-[#D4AF37]/50 -translate-x-full\" data-kid=\"91\"></div>\n                    <p class=\"text-xl font-['Source_Serif_4'] text-white/80 leading-relaxed italic\" data-kid=\"92\">\n                      Hardik asks Ishani if she \"saved it again,\" referring to his seat, and she confirms she wouldn't let anyone take it <span class=\"text-[11px] font-sans not-italic text-[#D4AF37] ml-2 tracking-widest\" data-kid=\"93\">[SOURCE 2]</span>.\n                    </p>\n                  </li>\n                </ul>\n              </div>\n\n              \n              <footer class=\"pt-8 flex flex-wrap gap-3\" data-kid=\"94\">\n                <div class=\"px-5 py-2 bg-[#003153]/40 border border-[#D4AF37]/20 rounded-sm hover:border-[#D4AF37] cursor-pointer group flex items-center gap-2\" data-kid=\"95\">\n                  <i class=\"ti ti-link text-[#D4AF37]/50 group-hover:text-[#D4AF37] transition-colors\" data-kid=\"96\"></i>\n                  <span class=\"text-[11px] uppercase tracking-widest font-sans text-white/60 group-hover:text-white transition-colors\" data-kid=\"97\">Excerpt-1_DTPP.pdf p.7</span>\n                </div>\n                <div class=\"px-5 py-2 bg-[#003153]/40 border border-[#D4AF37]/20 rounded-sm hover:border-[#D4AF37] cursor-pointer group flex items-center gap-2\" data-kid=\"98\">\n                  <i class=\"ti ti-link text-[#D4AF37]/50 group-hover:text-[#D4AF37] transition-colors\" data-kid=\"99\"></i>\n                  <span class=\"text-[11px] uppercase tracking-widest font-sans text-white/60 group-hover:text-white transition-colors\" data-kid=\"100\">Excerpt-1_DTPP.pdf p.4</span>\n                </div>\n                <div class=\"px-5 py-2 bg-[#003153]/40 border border-[#D4AF37]/20 rounded-sm hover:border-[#D4AF37] cursor-pointer group flex items-center gap-2\" data-kid=\"101\">\n                  <i class=\"ti ti-link text-[#D4AF37]/50 group-hover:text-[#D4AF37] transition-colors\" data-kid=\"102\"></i>\n                  <span class=\"text-[11px] uppercase tracking-widest font-sans text-white/60 group-hover:text-white transition-colors\" data-kid=\"103\">Excerpt-1_DTPP.pdf p.2</span>\n                </div>\n              </footer>\n            </article>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"relative z-40 pb-10 px-10\" data-kid=\"104\">\n      <div class=\"max-w-4xl mx-auto relative group\" data-kid=\"105\">\n        \n        <div class=\"bg-[#100C08]/80 backdrop-blur-3xl border border-[#D4AF37]/40 shadow-[0_40px_80px_-20px_rgba(0,0,0,0.9)] rounded-sm p-3 flex items-end gap-3 group-focus-within:border-[#D4AF37] group-focus-within:shadow-[0_40px_100px_-20px_rgba(212,175,55,0.15)] transition-all duration-700\" data-kid=\"106\">\n          <div class=\"flex-1 relative\" data-kid=\"107\">\n            <textarea rows=\"1\" placeholder=\"Consult the Script Library...\" class=\"w-full bg-transparent border-none focus:ring-hidden text-xl font-['Source_Serif_4'] text-white/95 placeholder:text-white/40 px-8 py-5 resize-none leading-relaxed overflow-hidden\" oninput=\"this.style.height = ''; this.style.height = this.scrollHeight + 'px'\" data-kid=\"108\"></textarea>\n            \n            \n            <div class=\"absolute left-8 -bottom-3 flex items-center gap-3 opacity-30 group-focus-within:opacity-100 transition-all duration-500\" data-kid=\"109\">\n               <div class=\"w-1.5 h-1.5 rounded-full bg-[#D4AF37] animate-pulse\" data-kid=\"110\"></div>\n               <span class=\"text-[8px] tracking-[0.5em] font-sans uppercase text-[#D4AF37]\" data-kid=\"111\">Active Terminal</span>\n            </div>\n          </div>\n          \n          <div class=\"flex items-center gap-3 p-2\" data-kid=\"112\">\n             <button class=\"w-14 h-14 flex items-center justify-center border border-white/5 hover:border-[#D4AF37]/40 hover:bg-[#D4AF37]/5 transition-all duration-500 rounded-sm group/btn\" data-kid=\"113\">\n                <i class=\"ti ti-paperclip text-white/20 group-hover/btn:text-[#D4AF37] transition-colors\" data-kid=\"114\"></i>\n             </button>\n             <button class=\"relative h-14 px-8 overflow-hidden bg-[#D4AF37] text-black font-sans text-[11px] font-black tracking-[0.3em] uppercase transition-transform duration-500 rounded-sm active:scale-95 group/send shadow-[0_0_30px_rgba(212,175,55,0.2)]\" data-kid=\"115\">\n                <span class=\"relative z-10 flex items-center gap-3\" data-kid=\"116\">\n                  <span data-kid=\"117\">Analyze</span>\n                  <i class=\"ti ti-sparkles\" data-kid=\"118\"></i>\n                </span>\n                <div class=\"absolute inset-0 bg-white/20 translate-y-full group-hover/send:translate-y-0 transition-transform duration-500\" data-kid=\"119\"></div>\n             </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </main>\n</section>\n\n<style data-kid=\"120\">\n  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Source+Serif+4:ital,opsz,wght@0,8..60,200..900;1,8..60,200..900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  /* Hide scrollbar but keep functionality */\n  #chat-scroller::-webkit-scrollbar {\n    width: 4px;\n  }\n  #chat-scroller::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  #chat-scroller::-webkit-scrollbar-thumb {\n    background: rgba(212, 175, 55, 0.1);\n    border-radius: 10px;\n  }\n  #chat-scroller::-webkit-scrollbar-thumb:hover {\n    background: rgba(212, 175, 55, 0.3);\n  }\n\n  /* Smooth reveal for typing target */\n  #typing-target {\n    visibility: visible !important;\n  }\n\n  /* Custom Drop Cap Styling */\n  .prose-container p::first-letter {\n    text-shadow: 2px 2px 0px rgba(212, 175, 55, 0.1);\n  }\n\n  /* Cinematic Grain Effect */\n  .grain {\n    position: fixed;\n    top: 0; left: 0;\n    width: 100%; height: 100%;\n    pointer-events: none;\n    z-index: 50;\n    opacity: 0.03;\n    background-image: url(\"https://images.unsplash.com/photo-1542385151-efd9000785a0?auto=format&w=1280&q=80&fit=crop\");\n    background-repeat: repeat;\n  }\n\n  /* Prevent FOUC for animated elements */\n  .ai-response {\n    will-change: transform, opacity;\n  }\n</style>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"121\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/TextPlugin.min.js\" data-kid=\"122\"></script>\n<script data-kid=\"123\">\n  gsap.registerPlugin(TextPlugin);\n\n  window.addEventListener('DOMContentLoaded', () => {\n    const aiResponse = document.querySelector('.ai-response');\n    const typingTarget = document.querySelector('#typing-target');\n    const originalText = typingTarget.innerText;\n\n    // Reset typing target text for animation\n    typingTarget.innerText = \"\";\n\n    const tl = gsap.timeline({ delay: 0.5 });\n\n    // Entrance animation\n    tl.to(aiResponse, {\n      opacity: 1,\n      y: 0,\n      duration: 1,\n      ease: \"power4.out\"\n    });\n\n    // Typing animation\n    tl.to(typingTarget, {\n      duration: 2.5,\n      text: originalText,\n      ease: \"none\",\n      onComplete: () => {\n        // Ensure drop cap styling is preserved if text plugin messed it up\n        // (TextPlugin can sometimes strip the special first-letter rendering if it treats it as a single node)\n        // In this case, we rely on the CSS which applies to the text node inside.\n      }\n    });\n\n    // Animate list items stagger\n    tl.from('.ai-response li', {\n      opacity: 0,\n      x: -20,\n      stagger: 0.2,\n      duration: 0.8,\n      ease: \"power2.out\"\n    }, \"-=1\");\n\n    // Animate source chips\n    tl.from('.ai-response footer div', {\n      opacity: 0,\n      y: 10,\n      stagger: 0.1,\n      duration: 0.5,\n      ease: \"back.out(1.7)\"\n    }, \"-=0.5\");\n  });\n</script>\n",
