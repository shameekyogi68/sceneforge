# Copy this file to .env and fill in real values before running.
# Do NOT commit .env to git.

# Google GenAI (Gemini) API key
GEMINI_API_KEY=

# Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=

# Supabase service role key (backend only — keep secret)
SUPABASE_SERVICE_KEY=

# Supabase anon/public key (safe for the frontend)
SUPABASE_ANON_KEY=

# Optional: override default chat model
# CHAT_MODEL=gemini-2.0-flash

# Optional: production deployment URL
# SITE_URL=https://your-app.reflex.run
# API_URL=https://your-app.reflex.run

# Optional: CORS origins (comma-separated). For single-origin deployments you
# usually do not need this.
# CORS_ALLOWED_ORIGINS=https://your-app.reflex.run
