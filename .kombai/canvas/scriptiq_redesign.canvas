      "html": "\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"0\">\n<style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Fira+Sans:wght@300;400;500;600&family=Fira+Code:wght@400;500&display=swap');\n\n    :root {\n        --color-bg: #010B13;\n        --color-navy: #011F5B;\n        --color-indigo: #6F00FF;\n        --color-aqua: #00CCFF;\n        --font-heading: 'Space Grotesk', sans-serif;\n        --font-body: 'Fira Sans', sans-serif;\n        --font-mono: 'Fira Code', monospace;\n    }\n\n    body {\n        background-color: var(--color-bg);\n        color: #F8FAFC;\n        font-family: var(--font-body);\n        margin: 0;\n        overflow-x: clip;\n    }\n\n    /* Custom Scrollbar */\n    ::-webkit-scrollbar {\n        width: 4px;\n    }\n    ::-webkit-scrollbar-track {\n        background: rgba(255, 255, 255, 0.02);\n    }\n    ::-webkit-scrollbar-thumb {\n        background: var(--color-indigo);\n        border-radius: 10px;\n    }\n\n    /* Patterns */\n    .dark-spotlight {\n        background: radial-gradient(circle at 50% 0%, rgba(0, 204, 255, 0.1) 0%, transparent 70%),\n                    radial-gradient(circle at 0% 100%, rgba(111, 0, 255, 0.05) 0%, transparent 50%);\n    }\n\n    .neon-inset {\n        border: 1.5px solid var(--color-aqua);\n        box-shadow: 0 0 15px rgba(64, 232, 232, 0.2), inset 0 0 30px rgba(64, 232, 232, 0.04);\n    }\n\n    .glassmorphism {\n        border: 1px solid rgba(255, 255, 255, 0.08);\n        background: rgba(255, 255, 255, 0.03);\n        backdrop-filter: blur(24px);\n        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);\n    }\n\n    .left-accent {\n        position: absolute;\n        top: 0;\n        bottom: 0;\n        left: 0;\n        width: 4px;\n        background: linear-gradient(180deg, var(--color-indigo), var(--color-aqua));\n        border-radius: 2px 0 0 2px;\n    }\n\n    .circuit-bg {\n        background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%236f00ff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4v-4H4v4H0v2h4v4h2v-4h4v-2H6zm30 0v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");\n    }\n\n    [data-scroll] {\n        opacity: 0;\n        transform: translateY(30px);\n    }\n\n    .toc-link.active {\n        color: var(--color-aqua);\n        border-left: 2px solid var(--color-aqua);\n        padding-left: 1rem;\n        transition: all 0.3s ease;\n    }\n\n    .tech-brutalist-btn {\n        background: transparent;\n        border: 1px solid var(--color-indigo);\n        color: white;\n        text-transform: uppercase;\n        letter-spacing: 0.3em;\n        font-weight: 700;\n        position: relative;\n        transition: all 0.2s ease;\n    }\n    .tech-brutalist-btn:hover {\n        background: var(--color-indigo);\n        box-shadow: 4px 4px 0px var(--color-aqua);\n        transform: translate(-2px, -2px);\n    }\n\n    .scanline {\n        width: 100%;\n        height: 100px;\n        z-index: 10;\n        background: linear-gradient(0deg, rgba(0, 204, 255, 0) 0%, rgba(0, 204, 255, 0.05) 50%, rgba(0, 204, 255, 0) 100%);\n        opacity: 0.1;\n        position: absolute;\n        bottom: 100%;\n        animation: scan 8s linear infinite;\n        pointer-events: none;\n    }\n\n    @keyframes scan {\n        0% { bottom: 100%; }\n        100% { bottom: -100px; }\n    }\n</style>\n\n\n<div class=\"fixed inset-0 z-[-1] circuit-bg\" data-kid=\"2\">\n    <div class=\"absolute inset-0 dark-spotlight\" data-kid=\"3\"></div>\n    <div class=\"absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none\" data-kid=\"4\">\n        <svg width=\"100%\" height=\"100%\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"5\">\n            <defs data-kid=\"6\">\n                <pattern id=\"grid\" width=\"40\" height=\"40\" patternUnits=\"userSpaceOnUse\" data-kid=\"7\">\n                    <path d=\"M 40 0 L 0 0 0 40\" fill=\"none\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"0.5\" data-kid=\"8\"></path>\n                </pattern>\n            </defs>\n            <rect width=\"100%\" height=\"100%\" fill=\"url(#grid)\" data-kid=\"9\"></rect>\n        </svg>\n    </div>\n</div>\n\n<div class=\"min-h-screen flex\" data-kid=\"10\">\n    \n    <aside class=\"w-20 border-r border-white/5 flex flex-col items-center py-8 gap-10 bg-[#010B13]/80 backdrop-blur-xl z-50 shrink-0\" data-kid=\"11\">\n        <div class=\"w-12 h-12 bg-gradient-to-br from-[#6F00FF] to-[#00CCFF] rounded-xl flex items-center justify-center shadow-[0_0_20px_rgba(111,0,255,0.3)] cursor-pointer group hover:scale-105 transition-transform\" data-kid=\"12\">\n            <i data-lucide=\"zap\" class=\"text-white w-6 h-6 group-hover:rotate-12\" data-kid=\"13\"></i>\n        </div>\n        \n        <nav class=\"flex flex-col gap-8\" data-kid=\"14\">\n            <div class=\"group relative flex flex-col items-center\" data-kid=\"15\">\n                <button class=\"p-3 rounded-xl text-white/30 hover:text-white hover:bg-white/5 transition-colors\" data-kid=\"16\">\n                    <i data-lucide=\"layout-grid\" class=\"w-6 h-6\" data-kid=\"17\"></i>\n                </button>\n            </div>\n            <div class=\"group relative flex flex-col items-center\" data-kid=\"18\">\n                <button class=\"p-3 rounded-xl text-white/30 hover:text-white hover:bg-white/5 transition-colors\" data-kid=\"19\">\n                    <i data-lucide=\"message-square\" class=\"w-6 h-6\" data-kid=\"20\"></i>\n                </button>\n            </div>\n            <div class=\"group relative flex flex-col items-center\" data-kid=\"21\">\n                <button class=\"p-3 rounded-xl text-[#00CCFF] bg-[#00CCFF]/10 transition-colors\" data-kid=\"22\">\n                    <i data-lucide=\"shield-check\" class=\"w-6 h-6\" data-kid=\"23\"></i>\n                </button>\n                <div class=\"absolute left-0 top-1/2 -translate-y-1/2 w-1 h-6 bg-[#00CCFF] rounded-r-full\" data-kid=\"24\"></div>\n            </div>\n            <div class=\"group relative flex flex-col items-center\" data-kid=\"25\">\n                <button class=\"p-3 rounded-xl text-white/30 hover:text-white hover:bg-white/5 transition-colors\" data-kid=\"26\">\n                    <i data-lucide=\"help-circle\" class=\"w-6 h-6\" data-kid=\"27\"></i>\n                </button>\n            </div>\n        </nav>\n\n        <div class=\"mt-auto flex flex-col gap-6 items-center\" data-kid=\"28\">\n            <button class=\"p-3 rounded-xl text-white/30 hover:text-red-400 hover:bg-red-400/5 transition-colors\" data-kid=\"29\">\n                <i data-lucide=\"log-out\" class=\"w-6 h-6\" data-kid=\"30\"></i>\n            </button>\n            <div class=\"w-10 h-10 rounded-full border-2 border-white/10 p-0.5 overflow-hidden ring-2 ring-[#6F00FF]/20\" data-kid=\"31\">\n                <img src=\"https://i.pravatar.cc/100?u=director\" alt=\"Avatar\" class=\"w-full h-full rounded-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"32\">\n            </div>\n        </div>\n    </aside>\n\n    \n    <main class=\"flex-1 overflow-y-auto px-12 py-16\" id=\"main-scroller\" data-kid=\"33\">\n        <div class=\"max-w-5xl mx-auto flex gap-16 relative\" data-kid=\"34\">\n            \n            \n            <aside class=\"w-64 shrink-0 hidden lg:block\" data-kid=\"35\">\n                <div class=\"sticky top-0 pt-4\" data-kid=\"36\">\n                    <div class=\"flex items-center gap-2 mb-8\" data-kid=\"37\">\n                        <div class=\"w-2 h-2 rounded-full bg-[var(--color-aqua)] animate-pulse\" data-kid=\"38\"></div>\n                        <span class=\"text-[10px] font-mono text-white/40 uppercase tracking-[0.3em]\" data-kid=\"39\">System.Directory</span>\n                    </div>\n                    <ul class=\"space-y-6 text-sm font-['Space_Grotesk'] uppercase tracking-widest text-white/30\" data-kid=\"40\">\n                        <li data-kid=\"41\"><a href=\"#intro\" class=\"toc-link block hover:text-white transition-colors\" data-kid=\"42\">Protocol Init</a></li>\n                        <li data-kid=\"43\"><a href=\"#access\" class=\"toc-link block hover:text-white transition-colors\" data-kid=\"44\">Access Auth</a></li>\n                        <li data-kid=\"45\"><a href=\"#assets\" class=\"toc-link block hover:text-white transition-colors\" data-kid=\"46\">Asset Retention</a></li>\n                        <li data-kid=\"47\"><a href=\"#privacy\" class=\"toc-link block hover:text-white transition-colors\" data-kid=\"48\">Neural Privacy</a></li>\n                        <li data-kid=\"49\"><a href=\"#security\" class=\"toc-link block hover:text-white transition-colors\" data-kid=\"50\">Data Security</a></li>\n                        <li data-kid=\"51\"><a href=\"#breach\" class=\"toc-link block hover:text-white transition-colors\" data-kid=\"52\">Protocol Breach</a></li>\n                        <li data-kid=\"53\"><a href=\"#contact\" class=\"toc-link block hover:text-white transition-colors\" data-kid=\"54\">Node Contact</a></li>\n                    </ul>\n\n                    <div class=\"mt-16 p-6 rounded-xl bg-[var(--color-indigo)]/5 border border-[var(--color-indigo)]/20\" data-kid=\"55\">\n                        <p class=\"text-[10px] font-mono text-[var(--color-aqua)] mb-4\" data-kid=\"56\">LEGAL_HELPDESK</p>\n                        <p class=\"text-xs text-white/60 leading-relaxed mb-4\" data-kid=\"57\">Direct neural link for legal inquiries regarding dataset licensing.</p>\n                        <button class=\"text-[10px] font-bold text-white uppercase tracking-widest flex items-center gap-2 hover:text-[var(--color-aqua)] transition-colors\" data-kid=\"58\">\n                            Initialize Query <i data-lucide=\"arrow-right\" class=\"w-3 h-3\" data-kid=\"59\"></i>\n                        </button>\n                    </div>\n                </div>\n            </aside>\n\n            \n            <div class=\"flex-1 pb-32\" data-kid=\"60\">\n                \n                <header class=\"mb-16\" data-scroll data-kid=\"61\">\n                    <div class=\"flex items-center justify-between mb-6\" data-kid=\"62\">\n                        <div class=\"flex items-center gap-3\" data-kid=\"63\">\n                            <span class=\"px-3 py-1 bg-[var(--color-indigo)]/20 border border-[var(--color-indigo)]/40 text-[var(--color-aqua)] text-[10px] font-mono tracking-widest uppercase rounded-full\" data-kid=\"64\">Doc.v4.02-Alpha</span>\n                            <div class=\"flex items-center gap-2 px-3 py-1 bg-white/5 border border-white/10 rounded-full\" data-kid=\"65\">\n                                <span class=\"w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse\" data-kid=\"66\"></span>\n                                <span class=\"text-[9px] font-mono text-white/40 uppercase tracking-widest\" data-kid=\"67\">System_Live</span>\n                            </div>\n                            <span class=\"text-white/20 text-[10px] font-mono uppercase tracking-[0.4em] ml-4\" data-kid=\"68\">Node: SCRIPT-IQ-LGL</span>\n                        </div>\n                        <span class=\"text-white/30 text-[10px] font-mono uppercase tracking-widest\" data-kid=\"69\">Modified: 2024.10.12 // 08:34 UTC</span>\n                    </div>\n                    <h1 class=\"text-6xl font-['Space_Grotesk'] font-bold tracking-tight text-white mb-6 leading-none\" data-kid=\"70\">\n                        Terms of Service & <br data-kid=\"71\">\n                        <span class=\"text-[var(--color-aqua)]\" data-kid=\"72\">Privacy Protocol</span>\n                    </h1>\n                    <div class=\"h-1 w-32 bg-gradient-to-r from-[var(--color-indigo)] to-[var(--color-aqua)] rounded-full mb-8\" data-kid=\"73\"></div>\n                    <p class=\"text-xl text-white/50 font-light max-w-2xl leading-relaxed\" data-kid=\"74\">\n                        Rigorous standards for neural data processing and script analysis within the ScriptIQ ecosystem.\n                    </p>\n                </header>\n\n                \n                <div class=\"glassmorphism rounded-3xl relative overflow-hidden\" data-scroll data-kid=\"75\">\n                    <div class=\"left-accent\" data-kid=\"76\"></div>\n                    <div class=\"scanline\" data-kid=\"77\"></div>\n                    \n                    <div class=\"p-16 space-y-24 relative z-20\" data-kid=\"78\">\n                        \n                        \n                        <section id=\"intro\" class=\"scroll-mt-20\" data-kid=\"79\">\n                            <div class=\"flex items-start gap-8\" data-kid=\"80\">\n                                <span class=\"text-[var(--color-aqua)] font-mono text-2xl font-bold shrink-0\" data-kid=\"81\">01</span>\n                                <div class=\"space-y-8 max-w-3xl\" data-kid=\"82\">\n                                    <h2 class=\"text-3xl font-['Space_Grotesk'] font-bold text-white uppercase tracking-wider\" data-kid=\"83\">Protocol Initialization</h2>\n                                    <div class=\"space-y-6 text-white/70 leading-relaxed text-lg\" data-kid=\"84\">\n                                        <p data-kid=\"85\">By accessing the ScriptIQ terminal and the \"Astra\" neural analysis engine, you (\"the Agent\") enter into a binding protocol with ScriptIQ Neural Dynamics. This document outlines the legal constraints, data harvesting methodologies, and creative protections enforced within our digital perimeter.</p>\n                                        <p data-kid=\"86\">Authorization is contingent upon full acceptance of these terms. Any deviation from the established protocols may result in automated account locking and neural link severance.</p>\n                                    </div>\n                                </div>\n                            </div>\n                        </section>\n\n                        \n                        <section id=\"access\" class=\"scroll-mt-20\" data-kid=\"87\">\n                            <div class=\"flex items-start gap-8\" data-kid=\"88\">\n                                <span class=\"text-[var(--color-aqua)] font-mono text-2xl font-bold shrink-0\" data-kid=\"89\">02</span>\n                                <div class=\"space-y-8 flex-1 max-w-3xl\" data-kid=\"90\">\n                                    <h2 class=\"text-3xl font-['Space_Grotesk'] font-bold text-white uppercase tracking-wider\" data-kid=\"91\">Access Authorization</h2>\n                                    <div class=\"space-y-6 text-white/70 leading-relaxed text-lg\" data-kid=\"92\">\n                                        <p data-kid=\"93\">Agents must maintain secure access tokens and refrain from sharing neural signatures. You are solely responsible for all script processing activities performed under your unique ID.</p>\n                                        <div class=\"neon-inset p-8 rounded-lg bg-white/[0.02] border-white/5 relative group overflow-hidden\" data-kid=\"94\">\n                                            <div class=\"absolute top-0 right-0 p-4 opacity-10 font-mono text-xs text-[var(--color-aqua)] uppercase tracking-widest\" data-kid=\"95\">\n                                                [SEC_ALERT]\n                                            </div>\n                                            <h3 class=\"text-[var(--color-aqua)] font-['Space_Grotesk'] font-bold text-xs uppercase tracking-[0.4em] mb-4 flex items-center gap-2\" data-kid=\"96\">\n                                                System Warning\n                                            </h3>\n                                            <p class=\"text-base text-white/80 leading-relaxed font-mono\" data-kid=\"97\">\n                                                \"Automated scripts or bot-driven data scraping of the ScriptIQ terminal is strictly prohibited. Detection triggers an immediate IP containment protocol.\"\n                                            </p>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </section>\n\n                        \n                        <section id=\"assets\" class=\"scroll-mt-20\" data-kid=\"98\">\n                            <div class=\"flex items-start gap-8\" data-kid=\"99\">\n                                <span class=\"text-[var(--color-aqua)] font-mono text-2xl font-bold shrink-0\" data-kid=\"100\">03</span>\n                                <div class=\"space-y-8 max-w-3xl\" data-kid=\"101\">\n                                    <h2 class=\"text-3xl font-['Space_Grotesk'] font-bold text-white uppercase tracking-wider\" data-kid=\"102\">Asset Retention Protocol</h2>\n                                    <div class=\"space-y-6 text-white/70 leading-relaxed text-lg\" data-kid=\"103\">\n                                        <p data-kid=\"104\">ScriptIQ does not claim ownership of scripts or world-building assets uploaded to the \"Astra\" engine. Your creative output remains your intellectual property.</p>\n                                        <div class=\"mt-8 border-l-2 border-white/10 pl-6 space-y-8\" data-kid=\"105\">\n                                            <div class=\"group\" data-kid=\"106\">\n                                                <div class=\"flex items-center gap-4 mb-2\" data-kid=\"107\">\n                                                    <span class=\"text-[var(--color-aqua)] font-mono text-[10px] uppercase tracking-widest\" data-kid=\"108\">[METADATA_PROTECT]</span>\n                                                    <h4 class=\"text-white font-bold uppercase tracking-widest text-sm\" data-kid=\"109\">Protected Metadata</h4>\n                                                </div>\n                                                <p class=\"text-sm text-white/50 leading-relaxed\" data-kid=\"110\">Structural data points are stored in an encrypted vault accessible only through your verified signature.</p>\n                                            </div>\n                                            <div class=\"group\" data-kid=\"111\">\n                                                <div class=\"flex items-center gap-4 mb-2\" data-kid=\"112\">\n                                                    <span class=\"text-[var(--color-aqua)] font-mono text-[10px] uppercase tracking-widest\" data-kid=\"113\">[PURGE_SYS]</span>\n                                                    <h4 class=\"text-white font-bold uppercase tracking-widest text-sm\" data-kid=\"114\">Purge Policy</h4>\n                                                </div>\n                                                <p class=\"text-sm text-white/50 leading-relaxed\" data-kid=\"115\">Deleted projects are scrubbed from all primary and secondary caches within 24 hours of deletion.</p>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </section>\n\n                        \n                        <section id=\"privacy\" class=\"scroll-mt-20\" data-kid=\"116\">\n                            <div class=\"flex items-start gap-8\" data-kid=\"117\">\n                                <span class=\"text-[var(--color-aqua)] font-mono text-2xl font-bold shrink-0\" data-kid=\"118\">04</span>\n                                <div class=\"space-y-8 max-w-3xl\" data-kid=\"119\">\n                                    <h2 class=\"text-3xl font-['Space_Grotesk'] font-bold text-white uppercase tracking-wider\" data-kid=\"120\">Neural Privacy Protocol</h2>\n                                    <div class=\"space-y-6 text-white/70 leading-relaxed text-lg\" data-kid=\"121\">\n                                        <p data-kid=\"122\">We believe in radical transparency regarding data harvesting. ScriptIQ collects the following data points to optimize neural link performance:</p>\n                                        <div class=\"space-y-4 font-mono text-xs uppercase tracking-widest text-white/40\" data-kid=\"123\">\n                                            <div class=\"flex items-center gap-3\" data-kid=\"124\">\n                                                <span class=\"text-[var(--color-aqua)]\" data-kid=\"125\">>></span>\n                                                <span class=\"text-white/70\" data-kid=\"126\">Terminal Telemetry</span>\n                                            </div>\n                                            <div class=\"flex items-center gap-3\" data-kid=\"127\">\n                                                <span class=\"text-[var(--color-aqua)]\" data-kid=\"128\">>></span>\n                                                <span class=\"text-white/70\" data-kid=\"129\">Processing Metrics</span>\n                                            </div>\n                                            <div class=\"flex items-center gap-3\" data-kid=\"130\">\n                                                <span class=\"text-[var(--color-aqua)]\" data-kid=\"131\">>></span>\n                                                <span class=\"text-white/70\" data-kid=\"132\">Asset Fingerprinting</span>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </section>\n\n                        \n                        <section id=\"security\" class=\"scroll-mt-20\" data-kid=\"133\">\n                            <div class=\"flex items-start gap-8\" data-kid=\"134\">\n                                <span class=\"text-[var(--color-aqua)] font-mono text-2xl font-bold shrink-0\" data-kid=\"135\">05</span>\n                                <div class=\"space-y-8 max-w-3xl\" data-kid=\"136\">\n                                    <h2 class=\"text-3xl font-['Space_Grotesk'] font-bold text-white uppercase tracking-wider\" data-kid=\"137\">Data Security</h2>\n                                    <div class=\"space-y-6 text-white/70 leading-relaxed text-lg\" data-kid=\"138\">\n                                        <p data-kid=\"139\">ScriptIQ utilizes industry-standard AES-256 encryption. Our infrastructure is compartmentalized to prevent lateral movement in the event of a perimeter breach.</p>\n                                        <div class=\"mt-8 p-6 bg-black/40 border-y border-white/5 flex gap-8 items-center\" data-kid=\"140\">\n                                            <div class=\"text-[var(--color-indigo)] font-mono text-sm uppercase tracking-[0.4em] rotate-180 [writing-mode:vertical-lr]\" data-kid=\"141\">DISTRIBUTED</div>\n                                            <div class=\"flex-1 space-y-2\" data-kid=\"142\">\n                                                <p class=\"text-white font-bold text-sm uppercase tracking-widest\" data-kid=\"143\">Neural Architecture v.9.4</p>\n                                                <p class=\"text-xs text-white/40 leading-relaxed font-mono\" data-kid=\"144\">Our servers are located in high-security zones across several geopolitical sectors to ensure maximum uptime and data sovereignty.</p>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </section>\n\n                        \n                        <section id=\"breach\" class=\"scroll-mt-20\" data-kid=\"145\">\n                            <div class=\"flex items-start gap-8\" data-kid=\"146\">\n                                <span class=\"text-[var(--color-aqua)] font-mono text-2xl font-bold shrink-0\" data-kid=\"147\">06</span>\n                                <div class=\"space-y-8 max-w-3xl\" data-kid=\"148\">\n                                    <h2 class=\"text-3xl font-['Space_Grotesk'] font-bold text-white uppercase tracking-wider\" data-kid=\"149\">Protocol Breach</h2>\n                                    <div class=\"space-y-6 text-white/70 leading-relaxed text-lg\" data-kid=\"150\">\n                                        <p data-kid=\"151\">Violation of these protocols leads to immediate countermeasures:</p>\n                                        <div class=\"space-y-2 font-mono text-xs\" data-kid=\"152\">\n                                            <div class=\"p-3 border border-red-500/10 bg-red-500/5 flex justify-between items-center\" data-kid=\"153\">\n                                                <span class=\"text-red-400 font-bold uppercase tracking-widest\" data-kid=\"154\">L-01 // Temporary Halt</span>\n                                                <span class=\"text-white/30 italic\" data-kid=\"155\">Verify Link</span>\n                                            </div>\n                                            <div class=\"p-3 border border-red-500/20 bg-red-500/10 flex justify-between items-center\" data-kid=\"156\">\n                                                <span class=\"text-red-400 font-bold uppercase tracking-widest\" data-kid=\"157\">L-02 // Asset Isolation</span>\n                                                <span class=\"text-white/30 italic\" data-kid=\"158\">Legal Review</span>\n                                            </div>\n                                            <div class=\"p-3 border border-red-500/40 bg-red-500/20 flex justify-between items-center\" data-kid=\"159\">\n                                                <span class=\"text-red-400 font-bold uppercase tracking-widest\" data-kid=\"160\">L-03 // Total Blacklist</span>\n                                                <span class=\"text-white/30 italic\" data-kid=\"161\">Sig. Revoked</span>\n                                            </div>\n                                        </div>\n                                    </div>\n                                </div>\n                            </div>\n                        </section>\n\n                    </div>\n                </div>\n\n                \n                <footer class=\"mt-20 pt-20 border-t border-white/5\" id=\"contact\" data-kid=\"162\">\n                    <div class=\"grid grid-cols-1 md:grid-cols-2 gap-12\" data-kid=\"163\">\n                        <div class=\"space-y-6\" data-kid=\"164\">\n                            <h3 class=\"text-2xl font-['Space_Grotesk'] font-bold text-white uppercase tracking-widest\" data-kid=\"165\">Protocol Contact</h3>\n                            <p class=\"text-white/40 leading-relaxed text-sm\" data-kid=\"166\">For legal inquiries, dataset licensing, or neural signature verification, please contact our Legal Dynamics division.</p>\n                            <div class=\"flex flex-col gap-4\" data-kid=\"167\">\n                                <div class=\"flex items-center gap-3 text-sm\" data-kid=\"168\">\n                                    <i data-lucide=\"mail\" class=\"w-4 h-4 text-[var(--color-aqua)]\" data-kid=\"169\"></i>\n                                    <span class=\"text-white/80\" data-kid=\"170\">legal@scriptiq.neural</span>\n                                </div>\n                                <div class=\"flex items-center gap-3 text-sm\" data-kid=\"171\">\n                                    <i data-lucide=\"globe\" class=\"w-4 h-4 text-[var(--color-aqua)]\" data-kid=\"172\"></i>\n                                    <span class=\"text-white/80\" data-kid=\"173\">https://scriptiq.io/legal-hub</span>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"glassmorphism p-8 rounded-lg flex flex-col justify-between border-white/5\" data-kid=\"174\">\n                            <div class=\"space-y-4\" data-kid=\"175\">\n                                <p class=\"text-[10px] font-mono text-white/40 uppercase tracking-[0.4em]\" data-kid=\"176\">Affirmation Protocol</p>\n                                <p class=\"text-sm text-white/60 font-mono leading-relaxed\" data-kid=\"177\">\"I acknowledge receipt and full processing of all protocols listed above.\"</p>\n                            </div>\n                            <button class=\"mt-8 tech-brutalist-btn py-4 flex items-center justify-center gap-3\" data-kid=\"178\">\n                                Initialize Acceptance <i data-lucide=\"power\" class=\"w-4 h-4\" data-kid=\"179\"></i>\n                            </button>\n                        </div>\n                    </div>\n                    <div class=\"mt-24 text-center\" data-kid=\"180\">\n                        <p class=\"text-[10px] font-mono text-white/40 uppercase tracking-[0.5em]\" data-kid=\"181\">&copy; 2024 SCRIPT-IQ NEURAL DYNAMICS. ALL PROTOCOLS ENFORCED.</p>\n                    </div>\n                </footer>\n            </div>\n        </div>\n    </main>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"182\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"183\"></script>\n<script data-kid=\"184\">gsap.registerPlugin(ScrollTrigger);</script>\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"185\"></script>\n<script type=\"module\" data-kid=\"186\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n    import Snap from \"https://esm.sh/lenis@1/snap\"\n\n    // Initialize Lucide Icons\n    lucide.createIcons();\n\n    // Initialize Lenis Smooth Scroll\n    const mainScroller = document.getElementById('main-scroller');\n    const lenis = new Lenis({\n        duration: 1.5,\n        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n        smoothWheel: true,\n        wrapper: mainScroller,\n        content: mainScroller.querySelector('div'),\n    });\n\n    // Synchronize Lenis with GSAP ScrollTrigger\n    lenis.on('scroll', ScrollTrigger.update);\n    gsap.ticker.add((time) => {\n        lenis.raf(time * 1000);\n    });\n    gsap.ticker.lagSmoothing(0);\n\n    // GSAP ScrollTrigger Animations\n    const scrollElements = document.querySelectorAll('[data-scroll]');\n    scrollElements.forEach(el => {\n        gsap.to(el, {\n            opacity: 1,\n            y: 0,\n            duration: 1,\n            ease: \"power3.out\",\n            scrollTrigger: {\n                trigger: el,\n                start: \"top 85%\",\n                scroller: \"#main-scroller\"\n            }\n        });\n    });\n\n    // TOC Active State Observer\n    const sections = document.querySelectorAll('section[id]');\n    const tocLinks = document.querySelectorAll('.toc-link');\n\n    const observerOptions = {\n        rootMargin: '-10% 0px -80% 0px',\n        threshold: 0\n    };\n\n    const observer = new IntersectionObserver((entries) => {\n        entries.forEach(entry => {\n            if (entry.isIntersecting) {\n                const id = entry.target.getAttribute('id');\n                tocLinks.forEach(link => {\n                    link.classList.remove('active');\n                    if (link.getAttribute('href') === `#${id}`) {\n                        link.classList.add('active');\n                    }\n                });\n            }\n        });\n    }, observerOptions);\n\n    sections.forEach(section => observer.observe(section));\n\n    // Handle smooth anchor clicks\n    tocLinks.forEach(link => {\n        link.addEventListener('click', (e) => {\n            e.preventDefault();\n            const targetId = link.getAttribute('href');\n            const targetElement = document.querySelector(targetId);\n            if (targetElement) {\n                lenis.scrollTo(targetElement, { offset: -40 });\n            }\n        });\n    });\n\n    // Add Hover Effects for TOC\n    tocLinks.forEach(link => {\n        link.addEventListener('mouseenter', () => {\n            gsap.to(link, { x: 5, color: '#00CCFF', duration: 0.3 });\n        });\n        link.addEventListener('mouseleave', () => {\n            if (!link.classList.contains('active')) {\n                gsap.to(link, { x: 0, color: 'rgba(255, 255, 255, 0.3)', duration: 0.3 });\n            }\n        });\n    });\n</script>\n",
      "comments": [],
      "created": "2026-06-24T10:16:18.703237+00:00",
      "modified": "2026-06-24T10:16:18.703237+00:00",
