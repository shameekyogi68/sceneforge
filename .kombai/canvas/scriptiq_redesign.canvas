 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"103\">\n                        <i data-lucide=\"arrow-up-right\" class=\"text-[#00CCFF] w-6 h-6\" data-kid=\"104\"></i>\n                    </div>\n                </div>\n\n                \n                <div class=\"project-card stacked-layer neon-inset glassmorphism rounded-2xl p-8 cursor-pointer group hover:scale-[1.02] active:scale-[0.98]\" data-kid=\"105\">\n                    <div class=\"flex justify-between items-start mb-12\" data-kid=\"106\">\n                        <div class=\"w-16 h-16 bg-white/5 rounded-2xl flex items-center justify-center border border-white/10 group-hover:scale-110 transition-transform\" data-kid=\"107\">\n                            <i data-lucide=\"folder\" class=\"text-white/40 w-8 h-8\" data-kid=\"108\"></i>\n                        </div>\n                        <button class=\"p-2 text-white/20 hover:text-red-400 hover:bg-red-400/10 rounded-lg transition-colors\" data-kid=\"109\">\n                            <i data-lucide=\"trash-2\" class=\"w-5 h-5\" data-kid=\"110\"></i>\n                        </button>\n                    </div>\n                    <div class=\"space-y-4\" data-kid=\"111\">\n                        <h4 class=\"text-3xl font-['Space_Grotesk'] font-bold group-hover:text-[#00CCFF] transition-colors tracking-tight\" data-kid=\"112\">a</h4>\n                        <div class=\"space-y-3\" data-kid=\"113\">\n                            <div class=\"flex items-center gap-2 text-white/80 text-xs font-mono font-bold\" data-kid=\"114\">\n                                <i data-lucide=\"file-text\" class=\"w-3.5 h-3.5 text-white/20\" data-kid=\"115\"></i>\n                                <span class=\"uppercase tracking-widest\" data-kid=\"116\">0 DOCUMENTS</span>\n                            </div>\n                            <div class=\"flex items-center gap-2 text-white/40 text-[10px] font-mono\" data-kid=\"117\">\n                                <i data-lucide=\"calendar\" class=\"w-3.5 h-3.5\" data-kid=\"118\"></i>\n                                <span class=\"uppercase tracking-widest\" data-kid=\"119\">MODIFIED: 2026-06-06</span>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"absolute bottom-6 right-8 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"120\">\n                        <i data-lucide=\"arrow-up-right\" class=\"text-[#00CCFF] w-6 h-6\" data-kid=\"121\"></i>\n                    </div>\n                </div>\n\n                \n                <div class=\"project-card border-2 border-dashed border-white/5 rounded-2xl p-8 flex flex-col items-center justify-center gap-4 group cursor-pointer hover:border-white/20 transition-colors min-h-[300px]\" data-kid=\"122\">\n                    <div class=\"w-14 h-14 rounded-full bg-white/5 flex items-center justify-center group-hover:bg-white/10 transition-colors\" data-kid=\"123\">\n                        <i data-lucide=\"plus\" class=\"text-white/40 w-7 h-7\" data-kid=\"124\"></i>\n                    </div>\n                    <span class=\"text-white/40 font-mono text-xs uppercase tracking-[0.3em] font-bold\" data-kid=\"125\">New Sequence</span>\n                </div>\n            </section>\n        </div>\n    </main>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"126\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"127\"></script>\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"128\"></script>\n<script type=\"module\" data-kid=\"129\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n\n    // Initialize Icons\n    lucide.createIcons();\n\n    // Initialize Lenis\n    const lenis = new Lenis({\n        wrapper: document.getElementById('dashboard-main'),\n        content: document.getElementById('scroll-content'),\n        duration: 1.2,\n        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n        smoothWheel: true,\n    });\n\n    function raf(time) {\n        lenis.raf(time);\n        requestAnimationFrame(raf);\n    }\n    requestAnimationFrame(raf);\n\n    // Entrance Animations\n    gsap.from(\".stat-card\", {\n        y: 30,\n        opacity: 0,\n        duration: 0.8,\n        stagger: 0.2,\n        ease: \"power4.out\"\n    });\n\n    gsap.from(\".project-card\", {\n        y: 40,\n        opacity: 0,\n        duration: 1,\n        stagger: 0.15,\n        delay: 0.4,\n        ease: \"power3.out\"\n    });\n\n    // Number counter animation for stats\n    function animateCounter(id, start, end, duration) {\n        let obj = { val: start };\n        gsap.to(obj, {\n            val: end,\n            duration: duration,\n            ease: \"power2.out\",\n            onUpdate: function() {\n                document.getElementById(id).innerHTML = Math.ceil(obj.val).toLocaleString();\n            }\n        });\n    }\n\n    animateCounter(\"stat-scripts\", 0, 1248, 2);\n    animateCounter(\"stat-insights\", 0, 8592, 2.5);\n\n</script>\n",
