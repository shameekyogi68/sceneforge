      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&family=IBM+Plex+Serif:ital,wght@0,400;0,500;1,400&display=swap');\n\n    :root {\n        --color-bg: #1B1B1B;\n        --color-panel: #343434;\n        --color-accent: #00B7EB;\n        --color-border: #343434;\n        --font-sans: 'IBM Plex Sans', sans-serif;\n        --font-serif: 'IBM Plex Serif', serif;\n    }\n\n    body {\n        background-color: var(--color-bg);\n        color: #ffffff;\n        margin: 0;\n        font-family: var(--font-sans);\n        overflow-x: clip;\n    }\n\n    .font-sans { font-family: var(--font-sans); }\n    .font-serif { font-family: var(--font-serif); }\n\n    .hairline-border {\n        border: 1px solid var(--color-border);\n    }\n\n    .notch-tag {\n        clip-path: polygon(15px 0%, 100% 0%, 100% 100%, 15px 100%, 0% 50%);\n        padding-left: 1.5rem;\n        padding-right: 0.75rem;\n    }\n\n    .marquee-v {\n        animation: marquee-vertical 40s linear infinite;\n    }\n\n    @keyframes marquee-vertical {\n        0% { transform: translateY(0); }\n        100% { transform: translateY(-50%); }\n    }\n\n    /* Custom Scrollbar for the systematic feel */\n    ::-webkit-scrollbar {\n        width: 4px;\n    }\n    ::-webkit-scrollbar-track {\n        background: var(--color-bg);\n    }\n    ::-webkit-scrollbar-thumb {\n        background: var(--color-panel);\n    }\n    ::-webkit-scrollbar-thumb:hover {\n        background: var(--color-accent);\n    }\n</style>\n\n<div class=\"flex h-screen w-full overflow-hidden\" data-kid=\"1\">\n    \n    <aside id=\"left-sidebar\" class=\"w-[20%] hairline-border border-l-0 border-t-0 border-b-0 bg-[#1B1B1B] flex flex-col items-center justify-between py-12 relative overflow-hidden\" data-kid=\"2\">\n        <div class=\"z-20 h-full flex items-center justify-center\" data-kid=\"3\">\n            <div class=\"rotate-[-90deg] whitespace-nowrap\" data-kid=\"4\">\n                <h1 class=\"text-8xl font-bold tracking-tighter uppercase text-[var(--color-accent)] opacity-90 leading-none\" data-kid=\"5\">ScriptIQ</h1>\n            </div>\n        </div>\n\n        <div class=\"absolute inset-0 opacity-[0.015] pointer-events-none flex flex-col justify-around py-20 text-[14rem] font-bold select-none overflow-hidden\" data-kid=\"6\">\n            <span class=\"rotate-90 leading-none translate-x-12 font-sans uppercase\" data-kid=\"7\">Ref:01</span>\n            <span class=\"rotate-90 leading-none -translate-x-12 font-sans uppercase\" data-kid=\"8\">Ref:02</span>\n            <span class=\"rotate-90 leading-none translate-x-12 font-sans uppercase\" data-kid=\"9\">Ref:03</span>\n        </div>\n\n        <div class=\"w-full px-6 z-20 mt-auto\" data-kid=\"10\">\n            <div class=\"h-[180px] overflow-hidden relative\" data-kid=\"11\">\n                <div class=\"absolute inset-x-0 top-0 h-8 bg-gradient-to-b from-[var(--color-bg)] to-transparent z-10\" data-kid=\"12\"></div>\n                <div class=\"absolute inset-x-0 bottom-0 h-8 bg-gradient-to-t from-[var(--color-bg)] to-transparent z-10\" data-kid=\"13\"></div>\n                <div class=\"marquee-v flex flex-col gap-6 items-center\" data-kid=\"14\">\n                    <span class=\"text-[10px] tracking-[0.5em] uppercase text-gray-500 font-sans font-semibold\" data-kid=\"15\">Cinematics</span>\n                    <span class=\"text-[10px] tracking-[0.5em] uppercase text-gray-500 font-sans font-semibold\" data-kid=\"16\">Narrative</span>\n                    <span class=\"text-[10px] tracking-[0.5em] uppercase text-gray-500 font-sans font-semibold\" data-kid=\"17\">Structure</span>\n                    <span class=\"text-[10px] tracking-[0.5em] uppercase text-gray-500 font-sans font-semibold\" data-kid=\"18\">Dialogue</span>\n                    <span class=\"text-[10px] tracking-[0.5em] uppercase text-gray-500 font-sans font-semibold\" data-kid=\"19\">Pacing</span>\n                    <span class=\"text-[10px] tracking-[0.5em] uppercase text-gray-500 font-sans font-semibold\" data-kid=\"20\">Arc</span>\n                    <span class=\"text-[10px] tracking-[0.5em] uppercase text-gray-500 font-sans font-semibold\" data-kid=\"21\">Analysis</span>\n                    \n                    <span class=\"text-[10px] tracking-[0.5em] uppercase text-gray-500 font-sans font-semibold\" data-kid=\"22\">Cinematics</span>\n                    <span class=\"text-[10px] tracking-[0.5em] uppercase text-gray-500 font-sans font-semibold\" data-kid=\"23\">Narrative</span>\n                    <span class=\"text-[10px] tracking-[0.5em] uppercase text-gray-500 font-sans font-semibold\" data-kid=\"24\">Structure</span>\n                    <span class=\"text-[10px] tracking-[0.5em] uppercase text-gray-500 font-sans font-semibold\" data-kid=\"25\">Dialogue</span>\n                    <span class=\"text-[10px] tracking-[0.5em] uppercase text-gray-500 font-sans font-semibold\" data-kid=\"26\">Pacing</span>\n                    <span class=\"text-[10px] tracking-[0.5em] uppercase text-gray-500 font-sans font-semibold\" data-kid=\"27\">Arc</span>\n                    <span class=\"text-[10px] tracking-[0.5em] uppercase text-gray-500 font-sans font-semibold\" data-kid=\"28\">Analysis</span>\n                </div>\n            </div>\n            <div class=\"mt-8 pt-8 border-t border-[var(--color-panel)] text-center\" data-kid=\"29\">\n                <p class=\"text-[9px] uppercase tracking-widest text-gray-500\" data-kid=\"30\">© 2026 ScriptIQ Institutional</p>\n            </div>\n        </div>\n    </aside>\n\n    \n    <main id=\"main-content\" class=\"w-[50%] bg-[#1B1B1B] flex flex-col h-full overflow-hidden\" data-kid=\"31\">\n        \n        <div class=\"p-10 border-b border-[var(--color-panel)] flex flex-col gap-10\" data-kid=\"32\">\n            <div class=\"flex justify-between items-start\" data-kid=\"33\">\n                <div data-kid=\"34\">\n                    <h2 class=\"text-5xl font-light tracking-tighter font-sans uppercase\" data-kid=\"35\">Your <span class=\"font-bold text-[var(--color-accent)]\" data-kid=\"36\">Projects</span></h2>\n                    <p class=\"text-gray-500 mt-3 font-serif italic text-base max-w-md leading-relaxed\" data-kid=\"37\">A rigorous diagnostic repository for advanced cinematic structure and dialogue analysis.</p>\n                </div>\n                <div class=\"flex items-center gap-4\" data-kid=\"38\">\n                    <button class=\"w-12 h-12 flex items-center justify-center border border-[var(--color-panel)] hover:border-[var(--color-accent)] transition-colors group\" data-kid=\"39\">\n                        <svg class=\"w-5 h-5 text-gray-500 group-hover:text-[var(--color-accent)]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"40\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\" data-kid=\"41\"></path></svg>\n                    </button>\n                    <button class=\"px-8 py-3 bg-[var(--color-accent)] text-[#1B1B1B] font-bold text-[10px] tracking-[0.25em] uppercase font-sans hover:bg-white transition-all transform hover:-translate-y-0.5 active:translate-y-0\" data-kid=\"42\">\n                        Initialise Project\n                    </button>\n                </div>\n            </div>\n            \n            \n            <div class=\"flex justify-between items-center text-[10px] tracking-[0.3em] uppercase text-gray-500 font-sans font-semibold\" data-kid=\"43\">\n                <div class=\"flex gap-6\" data-kid=\"44\">\n                    <span class=\"text-[var(--color-accent)] border-b border-[var(--color-accent)] pb-1 cursor-pointer\" data-kid=\"45\">All Projects</span>\n                    <span class=\"hover:text-white cursor-pointer transition-colors pb-1\" data-kid=\"46\">Recent</span>\n                    <span class=\"hover:text-white cursor-pointer transition-colors pb-1\" data-kid=\"47\">Archived</span>\n                </div>\n                <div class=\"flex items-center gap-4\" data-kid=\"48\">\n                    <span class=\"text-gray-400\" data-kid=\"49\">Sort: Date Modified</span>\n                    <svg class=\"w-3 h-3 text-[var(--color-accent)]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"50\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\" data-kid=\"51\"></path></svg>\n                </div>\n            </div>\n        </div>\n\n        \n        <div class=\"flex-1 overflow-y-auto px-10 py-6\" data-kid=\"52\">\n            <table class=\"w-full text-left border-collapse\" data-kid=\"53\">\n                <thead data-kid=\"54\">\n                    <tr class=\"text-gray-500 text-[10px] tracking-[0.3em] uppercase border-b border-[var(--color-panel)]\" data-kid=\"55\">\n                        <th class=\"py-6 font-semibold w-[35%]\" data-kid=\"56\">Project Identity</th>\n                        <th class=\"py-6 font-semibold w-[10%]\" data-kid=\"57\">Docs</th>\n                        <th class=\"py-6 font-semibold w-[20%]\" data-kid=\"58\">Last Audit</th>\n                        <th class=\"py-6 font-semibold w-[20%]\" data-kid=\"59\">Structural Flux</th>\n                        <th class=\"py-6 font-semibold w-[15%] text-right\" data-kid=\"60\">Operational State</th>\n                    </tr>\n                </thead>\n                <tbody id=\"project-list\" class=\"divide-y divide-[var(--color-panel)]/40\" data-kid=\"61\">\n                    \n                    <tr class=\"project-row group hover:bg-[var(--color-accent)]/5 transition-colors cursor-pointer\" data-kid=\"62\">\n                        <td class=\"py-10 pr-6\" data-kid=\"63\">\n                            <div class=\"flex items-center gap-5\" data-kid=\"64\">\n                                <div class=\"w-[2px] h-10 bg-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-all duration-300\" data-kid=\"65\"></div>\n                                <div data-kid=\"66\">\n                                    <div class=\"text-3xl font-sans font-bold text-[var(--color-accent)] tracking-tighter group-hover:translate-x-1 transition-transform\" data-kid=\"67\">abc</div>\n                                    <div class=\"text-[11px] text-gray-500 font-sans mt-2 uppercase tracking-[0.2em] font-medium\" data-kid=\"68\">Index Reference: <span class=\"text-gray-300\" data-kid=\"69\">PRJ-9921-X</span></div>\n                                </div>\n                            </div>\n                        </td>\n                        <td class=\"py-10\" data-kid=\"70\">\n                            <span class=\"font-serif text-2xl text-gray-200\" data-kid=\"71\">01</span>\n                        </td>\n                        <td class=\"py-10\" data-kid=\"72\">\n                            <div class=\"font-serif text-base text-gray-300\" data-kid=\"73\">2026.06.06</div>\n                            <div class=\"text-[10px] text-gray-500 font-sans uppercase tracking-[0.1em] mt-1.5 font-bold\" data-kid=\"74\">14:02:44 UTC</div>\n                        </td>\n                        <td class=\"py-10\" data-kid=\"75\">\n                            <div class=\"w-32 h-12 flex items-center\" data-kid=\"76\">\n                                <svg class=\"w-full h-full\" viewBox=\"0 0 100 40\" preserveAspectRatio=\"none\" data-kid=\"77\">\n                                    <path d=\"M0 35 Q 25 5, 50 15 T 100 10\" fill=\"none\" stroke=\"var(--color-accent)\" stroke-width=\"2.5\" data-kid=\"78\"></path>\n                                    <circle cx=\"100\" cy=\"10\" r=\"3\" fill=\"var(--color-accent)\" class=\"animate-pulse\" data-kid=\"79\"></circle>\n                                </svg>\n                            </div>\n                        </td>\n                        <td class=\"py-10 text-right\" data-kid=\"80\">\n                            <div class=\"inline-block notch-tag bg-[var(--color-accent)] text-[#1B1B1B] text-[10px] font-black uppercase tracking-[0.2em] py-1.5 shadow-[0_0_15px_rgba(0,183,235,0.3)]\" data-kid=\"81\">Analyzed</div>\n                        </td>\n                    </tr>\n                    \n                    <tr class=\"project-row group hover:bg-[var(--color-panel)]/20 transition-colors cursor-pointer\" data-kid=\"82\">\n                        <td class=\"py-10 pr-6\" data-kid=\"83\">\n                            <div class=\"flex items-center gap-5\" data-kid=\"84\">\n                                <div class=\"w-[2px] h-10 bg-gray-600 opacity-0 group-hover:opacity-100 transition-all duration-300\" data-kid=\"85\"></div>\n                                <div data-kid=\"86\">\n                                    <div class=\"text-3xl font-sans font-bold text-gray-200 tracking-tighter group-hover:text-white transition-colors\" data-kid=\"87\">a</div>\n                                    <div class=\"text-[11px] text-gray-500 font-sans mt-2 uppercase tracking-[0.2em] font-medium\" data-kid=\"88\">Index Reference: <span class=\"text-gray-400\" data-kid=\"89\">PRJ-9904-B</span></div>\n                                </div>\n                            </div>\n                        </td>\n                        <td class=\"py-10\" data-kid=\"90\">\n                            <span class=\"font-serif text-2xl text-gray-400\" data-kid=\"91\">00</span>\n                        </td>\n                        <td class=\"py-10\" data-kid=\"92\">\n                            <div class=\"font-serif text-base text-gray-400\" data-kid=\"93\">2026.06.06</div>\n                            <div class=\"text-[10px] text-gray-600 font-sans uppercase tracking-[0.1em] mt-1.5 font-bold\" data-kid=\"94\">09:45:12 UTC</div>\n                        </td>\n                        <td class=\"py-10\" data-kid=\"95\">\n                            <div class=\"w-32 h-12 flex items-center opacity-40 group-hover:opacity-100 transition-opacity\" data-kid=\"96\">\n                                <svg class=\"w-full h-full\" viewBox=\"0 0 100 40\" preserveAspectRatio=\"none\" data-kid=\"97\">\n                                    <path d=\"M0 20 L 20 25 L 40 15 L 60 30 L 80 10 L 100 20\" fill=\"none\" stroke=\"var(--color-panel)\" stroke-width=\"2\" class=\"group-hover:stroke-gray-400 transition-colors\" data-kid=\"98\"></path>\n                                </svg>\n                            </div>\n                        </td>\n                        <td class=\"py-10 text-right\" data-kid=\"99\">\n                            <div class=\"inline-block notch-tag bg-[var(--color-panel)] text-gray-400 text-[10px] font-bold uppercase tracking-[0.2em] py-1.5\" data-kid=\"100\">Standby</div>\n                        </td>\n                    </tr>\n                    \n                    <tr class=\"project-row group opacity-30\" data-kid=\"101\">\n                        <td class=\"py-10 pr-6\" data-kid=\"102\">\n                            <div class=\"flex items-center gap-5\" data-kid=\"103\">\n                                <div class=\"w-[2px] h-10 bg-transparent\" data-kid=\"104\"></div>\n                                <div data-kid=\"105\">\n                                    <div class=\"text-3xl font-sans font-bold text-gray-600 tracking-tighter\" data-kid=\"106\">Project Delta</div>\n                                    <div class=\"text-[11px] text-gray-700 font-sans mt-2 uppercase tracking-[0.2em] font-medium\" data-kid=\"107\">Index Reference: <span class=\"text-gray-800\" data-kid=\"108\">PRJ-XXXX-Y</span></div>\n                                </div>\n                            </div>\n                        </td>\n                        <td class=\"py-10\" data-kid=\"109\"><span class=\"font-serif text-2xl text-gray-700\" data-kid=\"110\">--</span></td>\n                        <td class=\"py-10\" data-kid=\"111\"><div class=\"font-serif text-base text-gray-700\" data-kid=\"112\">----.--.--</div></td>\n                        <td class=\"py-10\" data-kid=\"113\"></td>\n                        <td class=\"py-10 text-right\" data-kid=\"114\">\n                             <div class=\"inline-block notch-tag bg-transparent border border-gray-600 text-gray-600 text-[10px] font-bold uppercase tracking-[0.2em] py-1.5\" data-kid=\"115\">Pending</div>\n                        </td>\n                    </tr>\n                </tbody>\n            </table>\n            \n            <div class=\"mt-8 py-10 border-t border-[var(--color-panel)] flex justify-center opacity-30\" data-kid=\"116\">\n                <p class=\"text-[10px] tracking-[0.5em] uppercase font-sans\" data-kid=\"117\">End of Archive Reach</p>\n            </div>\n        </div>\n    </main>\n\n    \n    <aside id=\"right-panel\" class=\"w-[30%] h-full relative hairline-border border-r-0 border-t-0 border-b-0 overflow-hidden\" data-kid=\"118\">\n        <img src=\"https://images.unsplash.com/photo-1505682634904-d7c8d95cdc50?auto=format&w=1200&q=80\" alt=\"Vintage Typewriter\" class=\"absolute inset-0 w-full h-full object-cover grayscale brightness-[0.4]\" loading=\"lazy\" decoding=\"async\" data-kid=\"119\">\n        \n        <div class=\"absolute inset-0 opacity-[0.03] pointer-events-none\" style=\"background-image: linear-gradient(var(--color-accent) 1px, transparent 1px), linear-gradient(90deg, var(--color-accent) 1px, transparent 1px); background-size: 40px 40px;\" data-kid=\"120\"></div>\n        \n        \n        <div class=\"absolute inset-0 flex flex-col justify-end p-12 bg-gradient-to-t from-[#1B1B1B] via-transparent to-transparent\" data-kid=\"121\">\n            <div id=\"side-callout\" class=\"border border-[var(--color-accent)]/40 bg-[#1B1B1B]/90 backdrop-blur-xl p-10 transform translate-y-0 shadow-2xl\" data-kid=\"122\">\n                <div class=\"flex items-center gap-3 mb-6\" data-kid=\"123\">\n                    <div class=\"w-8 h-[1px] bg-[var(--color-accent)]\" data-kid=\"124\"></div>\n                    <span class=\"text-[10px] text-[var(--color-accent)] uppercase tracking-[0.4em] font-sans font-bold\" data-kid=\"125\">System Protocol</span>\n                </div>\n                \n                <h3 class=\"font-serif text-3xl leading-snug text-white italic mb-8\" data-kid=\"126\">\n                    \"The best way to <span class=\"text-[var(--color-accent)]\" data-kid=\"127\">begin</span> is just to start!\"\n                </h3>\n                \n                <div class=\"space-y-4\" data-kid=\"128\">\n                    <div class=\"flex justify-between items-center text-[9px] uppercase tracking-[0.2em] text-gray-500\" data-kid=\"129\">\n                        <span data-kid=\"130\">Terminal Engine</span>\n                        <span class=\"text-gray-300\" data-kid=\"131\">v4.0.1_ScriptIQ</span>\n                    </div>\n                    <div class=\"flex justify-between items-center text-[9px] uppercase tracking-[0.2em] text-gray-500\" data-kid=\"132\">\n                        <span data-kid=\"133\">Uptime Status</span>\n                        <div class=\"flex items-center gap-2\" data-kid=\"134\">\n                            <span class=\"text-[var(--color-accent)]\" data-kid=\"135\">Operational</span>\n                            <div class=\"w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] animate-pulse\" data-kid=\"136\"></div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"mt-10 pt-8 border-t border-[var(--color-panel)]\" data-kid=\"137\">\n                    <p class=\"text-[11px] leading-relaxed text-gray-400 font-sans tracking-widest uppercase italic font-medium opacity-80\" data-kid=\"138\">\n                        System authorized for high-fidelity cinematic research. All document audits are strictly logged for narrative integrity.\n                    </p>\n                </div>\n            </div>\n        </div>\n        \n        \n        <div class=\"absolute top-0 right-0 p-8\" data-kid=\"139\">\n            <div class=\"w-16 h-16 border-t-2 border-r-2 border-[var(--color-accent)] opacity-20\" data-kid=\"140\"></div>\n        </div>\n    </aside>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"141\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"142\"></script>\n<script type=\"module\" data-kid=\"143\">\n    import { animate, inView, stagger } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n    // GSAP Entrances\n    window.onload = () => {\n        gsap.registerPlugin(ScrollTrigger);\n\n        // Sidebar Sliders\n        gsap.from(\"#left-sidebar\", {\n            xPercent: -100,\n            duration: 1.2,\n            ease: \"expo.out\",\n            delay: 0.1\n        });\n\n        gsap.from(\"#right-panel\", {\n            xPercent: 100,\n            duration: 1.2,\n            ease: \"expo.out\",\n            delay: 0.2\n        });\n\n        // Center Panel Slide Up\n        gsap.from(\"#main-content\", {\n            y: 50,\n            autoAlpha: 0,\n            duration: 1,\n            ease: \"power3.out\",\n            delay: 0.4\n        });\n\n        // Right Detail Panel Float-In\n        gsap.from(\"#side-callout\", {\n            y: 100,\n            autoAlpha: 0,\n            duration: 1.4,\n            ease: \"power4.out\",\n            delay: 0.8\n        });\n\n        // Motion.js List Stagger\n        inView(\"#project-list\", ({ target }) => {\n            const rows = target.querySelectorAll(\".project-row\");\n            animate(rows, \n                { opacity: [0, 1], y: [30, 0] },\n                { \n                    delay: stagger(0.12, { start: 0.6 }),\n                    duration: 0.8,\n                    easing: [0.16, 1, 0.3, 1] // Custom expo-like easing\n                }\n            );\n        });\n    };\n</script>\n",
