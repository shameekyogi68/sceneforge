      "html": "\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"0\">\n<style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Fira+Sans:wght@300;400;500;600&family=Fira+Code:wght@400;500&display=swap');\n\n    :root {\n        --color-bg: #010B13;\n        --color-navy: #011F5B;\n        --color-indigo: #6F00FF;\n        --color-aqua: #00CCFF;\n        --font-heading: 'Space Grotesk', sans-serif;\n        --font-body: 'Fira Sans', sans-serif;\n        --font-mono: 'Fira Code', monospace;\n    }\n\n    body {\n        background-color: var(--color-bg);\n        color: #F8FAFC;\n        font-family: var(--font-body);\n        margin: 0;\n        overflow-x: clip;\n    }\n\n    /* Custom Scrollbar */\n    ::-webkit-scrollbar {\n        width: 4px;\n    }\n    ::-webkit-scrollbar-track {\n        background: rgba(255, 255, 255, 0.02);\n    }\n    ::-webkit-scrollbar-thumb {\n        background: var(--color-indigo);\n        border-radius: 10px;\n    }\n\n    /* Patterns */\n    .dark-spotlight {\n        background: radial-gradient(circle at 50% 0%, rgba(0, 204, 255, 0.15) 0%, transparent 70%),\n                    radial-gradient(circle at 0% 0%, rgba(111, 0, 255, 0.1) 0%, transparent 50%),\n                    linear-gradient(to bottom, transparent, rgba(1, 11, 19, 0.8));\n    }\n\n    .neon-inset {\n        border: 1.5px solid transparent;\n        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n    }\n    .neon-inset:hover {\n        border-color: var(--color-aqua);\n        box-shadow: 0 0 15px rgba(64, 232, 232, 0.2), inset 0 0 30px rgba(64, 232, 232, 0.04);\n    }\n\n    .neon-tube {\n        position: absolute;\n        inset: -1.5px;\n        background: linear-gradient(90deg, var(--color-indigo), var(--color-aqua));\n        border-radius: inherit;\n        z-index: -1;\n        opacity: 0.05;\n        filter: blur(3px);\n        transition: opacity 0.3s ease, filter 0.3s ease, box-shadow 0.3s ease;\n    }\n    .group:focus-within .neon-tube {\n        opacity: 1;\n        filter: blur(8px);\n        box-shadow: 0 0 25px rgba(0, 204, 255, 0.5);\n    }\n\n    .glassmorphism {\n        border: 1px solid rgba(255, 255, 255, 0.08);\n        background: rgba(255, 255, 255, 0.04);\n        backdrop-filter: blur(12px);\n        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);\n    }\n\n    .stacked-layer {\n        position: relative;\n        z-index: 10;\n    }\n    .stacked-layer::before {\n        content: '';\n        position: absolute;\n        inset: 0;\n        background: rgba(255, 255, 255, 0.02);\n        border: 1px solid rgba(255, 255, 255, 0.05);\n        border-radius: 1.5rem;\n        z-index: -1;\n        transform: translate(8px, 8px);\n        backdrop-filter: blur(4px);\n        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);\n    }\n    .stacked-layer::after {\n        content: '';\n        position: absolute;\n        inset: 0;\n        background: rgba(255, 255, 255, 0.01);\n        border: 1px solid rgba(255, 255, 255, 0.03);\n        border-radius: 1.5rem;\n        z-index: -2;\n        transform: translate(16px, 16px);\n        backdrop-filter: blur(2px);\n        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);\n    }\n    .stacked-layer:hover::before { transform: translate(12px, 12px); }\n    .stacked-layer:hover::after { transform: translate(24px, 24px); }\n\n    .circuit-bg {\n        background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%236f00ff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4v-4H4v4H0v2h4v4h2v-4h4v-2H6zm30 0v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");\n    }\n\n    .indigo-glow {\n        box-shadow: 0 0 20px rgba(111, 0, 255, 0.4);\n    }\n</style>\n\n<div class=\"fixed inset-0 z-[-1]\" data-kid=\"2\">\n    <img src=\"https://images.pexels.com/photos/34742154/pexels-photo-34742154.jpeg?auto=compress&cs=tinysrgb&w=1920&q=80\" class=\"w-full h-full object-cover opacity-15 grayscale brightness-50\" alt=\"Background\" decoding=\"async\" loading=\"lazy\" data-kid=\"3\">\n    <div class=\"absolute inset-0 dark-spotlight bg-[#010B13]/85\" data-kid=\"4\"></div>\n</div>\n\n<div class=\"flex h-screen w-full overflow-hidden circuit-bg\" id=\"main-container\" data-kid=\"5\">\n    \n    \n    <aside class=\"w-20 border-r border-white/5 flex flex-col items-center py-8 gap-10 bg-[#010B13]/90 backdrop-blur-xl z-50\" data-kid=\"6\">\n        <div class=\"w-12 h-12 bg-gradient-to-br from-[#6F00FF] to-[#00CCFF] rounded-xl flex items-center justify-center shadow-[0_0_20px_rgba(111,0,255,0.3)] cursor-pointer group hover:scale-105 transition-transform\" data-kid=\"7\">\n            <i data-lucide=\"zap\" class=\"text-white w-6 h-6 group-hover:rotate-12\" data-kid=\"8\"></i>\n        </div>\n        \n        <nav class=\"flex flex-col gap-8\" data-kid=\"9\">\n            <div class=\"group relative flex flex-col items-center\" data-kid=\"10\">\n                <button class=\"p-3 rounded-xl text-[#00CCFF] bg-[#00CCFF]/10\" data-kid=\"11\">\n                    <i data-lucide=\"layout-grid\" class=\"w-6 h-6\" data-kid=\"12\"></i>\n                </button>\n                <div class=\"absolute left-0 top-1/2 -translate-y-1/2 w-1 h-6 bg-[#00CCFF] rounded-r-full\" data-kid=\"13\"></div>\n            </div>\n            <div class=\"group relative flex flex-col items-center\" data-kid=\"14\">\n                <button class=\"p-3 rounded-xl text-white/30 hover:text-white hover:bg-white/5 transition-all\" data-kid=\"15\">\n                    <i data-lucide=\"message-square\" class=\"w-6 h-6\" data-kid=\"16\"></i>\n                </button>\n            </div>\n            <div class=\"group relative flex flex-col items-center\" data-kid=\"17\">\n                <button class=\"p-3 rounded-xl text-white/30 hover:text-white hover:bg-white/5 transition-all\" data-kid=\"18\">\n                    <i data-lucide=\"library\" class=\"w-6 h-6\" data-kid=\"19\"></i>\n                </button>\n            </div>\n            <div class=\"group relative flex flex-col items-center\" data-kid=\"20\">\n                <button class=\"p-3 rounded-xl text-white/30 hover:text-white hover:bg-white/5 transition-all\" data-kid=\"21\">\n                    <i data-lucide=\"git-branch\" class=\"w-6 h-6\" data-kid=\"22\"></i>\n                </button>\n            </div>\n        </nav>\n\n        <div class=\"mt-auto flex flex-col gap-6 items-center\" data-kid=\"23\">\n            <button class=\"p-3 rounded-xl text-white/30 hover:text-red-400 hover:bg-red-400/5 transition-all\" data-kid=\"24\">\n                <i data-lucide=\"log-out\" class=\"w-6 h-6\" data-kid=\"25\"></i>\n            </button>\n            <div class=\"w-10 h-10 rounded-full border-2 border-white/10 p-0.5 overflow-hidden ring-2 ring-[#6F00FF]/20 cursor-pointer\" data-kid=\"26\">\n                <img src=\"https://i.pravatar.cc/100?u=director\" alt=\"Avatar\" class=\"w-full h-full rounded-full object-cover\" data-kid=\"27\">\n            </div>\n        </div>\n    </aside>\n\n    \n    <main class=\"flex-1 flex flex-col overflow-y-auto custom-scrollbar bg-[#010B13]/30 backdrop-blur-sm\" id=\"dashboard-main\" data-kid=\"28\">\n        \n        \n        <header class=\"h-20 border-b border-white/5 flex items-center justify-between px-10 sticky top-0 z-40 bg-[#010B13]/60 backdrop-blur-2xl\" data-kid=\"29\">\n            <div class=\"flex items-center gap-12\" data-kid=\"30\">\n                <div class=\"flex flex-col\" data-kid=\"31\">\n                    <div class=\"flex items-center gap-2\" data-kid=\"32\">\n                        <span class=\"text-[10px] font-mono text-[#6F00FF] tracking-widest uppercase\" data-kid=\"33\">Dashboard_Root</span>\n                        <div class=\"w-1.5 h-1.5 rounded-full bg-[#00CCFF] animate-pulse\" data-kid=\"34\"></div>\n                    </div>\n                    <h2 class=\"font-['Space_Grotesk'] text-lg font-bold tracking-tight\" data-kid=\"35\">ScriptIQ Analyst Terminal</h2>\n                </div>\n                \n                <div class=\"relative group w-96\" data-kid=\"36\">\n                    <div class=\"neon-tube\" data-kid=\"37\"></div>\n                    <div class=\"bg-[#011F5B]/70 border border-white/25 rounded-xl px-4 flex items-center gap-3 h-11 transition-all group-focus-within:border-[#00CCFF]/60 shadow-[inset_0_2px_8px_rgba(0,0,0,0.4)]\" data-kid=\"38\">\n                        <i data-lucide=\"search\" class=\"text-white/60 w-4 h-4\" data-kid=\"39\"></i>\n                        <input type=\"text\" placeholder=\"Search projects, scripts, or insights...\" class=\"bg-transparent border-none outline-none text-sm w-full placeholder:text-white/50 text-white font-bold tracking-tight\" data-kid=\"40\">\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"flex items-center gap-6\" data-kid=\"41\">\n                <div class=\"hidden xl:flex items-center gap-3 bg-white/5 px-4 py-2 rounded-full border border-white/10\" data-kid=\"42\">\n                    <i data-lucide=\"cpu\" class=\"text-[#00CCFF] w-4 h-4\" data-kid=\"43\"></i>\n                    <span class=\"text-[10px] font-mono text-white/60 tracking-wider\" data-kid=\"44\">CORE_LATENCY: 12ms</span>\n                </div>\n                <button class=\"bg-[#6F00FF] indigo-glow text-white px-5 py-2.5 rounded-xl flex items-center gap-2 font-bold hover:bg-[#7F1FFF] transition-all active:scale-95 text-sm shadow-[0_0_20px_rgba(111,0,255,0.3)]\" data-kid=\"45\">\n                    <i data-lucide=\"plus\" class=\"w-4 h-4\" data-kid=\"46\"></i>\n                    New Project\n                </button>\n            </div>\n        </header>\n\n        <div id=\"scroll-content\" data-kid=\"47\">\n            \n            <section class=\"p-10 grid grid-cols-12 gap-8\" id=\"hero-stat\" data-kid=\"48\">\n                \n                <div class=\"stat-card col-span-12 lg:col-span-6 glassmorphism p-10 rounded-3xl relative overflow-hidden group border-l-4 border-l-[#00CCFF] bg-linear-to-br from-white/[0.06] to-transparent\" data-kid=\"49\">\n                    <div class=\"relative z-10 flex flex-col h-full justify-between\" data-kid=\"50\">\n                        <div class=\"flex justify-between items-start\" data-kid=\"51\">\n                            <div data-kid=\"52\">\n                                <span class=\"text-[12px] font-mono font-bold tracking-[0.5em] text-[#00CCFF] uppercase\" data-kid=\"53\">Master Terminal Volume</span>\n                                <p class=\"text-white/60 mt-2 font-medium\" data-kid=\"54\">Real-time script analysis depth</p>\n                            </div>\n                            <div class=\"w-16 h-16 rounded-2xl bg-[#00CCFF]/10 flex items-center justify-center border border-[#00CCFF]/20 group-hover:scale-110 transition-transform shadow-[0_0_20px_rgba(0,204,255,0.2)]\" data-kid=\"55\">\n                                <i data-lucide=\"file-search\" class=\"text-[#00CCFF] w-8 h-8\" data-kid=\"56\"></i>\n                            </div>\n                        </div>\n                        <div class=\"mt-12 flex items-baseline gap-4 relative\" data-kid=\"57\">\n                            <h3 class=\"text-7xl font-['Space_Grotesk'] font-bold tracking-tighter\" id=\"stat-scripts\" data-kid=\"58\">1,248</h3>\n                            <div class=\"flex items-center gap-2 px-3 py-1 bg-[#00CCFF]/10 border border-[#00CCFF]/30 rounded-full\" data-kid=\"59\">\n                                <span class=\"w-1.5 h-1.5 bg-[#00CCFF] rounded-full animate-ping\" data-kid=\"60\"></span>\n                                <span class=\"text-[#00CCFF] font-mono font-bold text-[10px] tracking-widest uppercase\" data-kid=\"61\">Active_Session</span>\n                            </div>\n                        </div>\n                    </div>\n                    \n                    <div class=\"absolute -right-20 -bottom-20 w-80 h-80 bg-[#00CCFF]/5 blur-3xl rounded-full\" data-kid=\"62\"></div>\n                </div>\n                \n                \n                <div class=\"stat-card col-span-12 md:col-span-6 lg:col-span-3 glassmorphism p-8 rounded-3xl relative overflow-hidden group border-l-4 border-l-[#6F00FF]\" data-kid=\"63\">\n                    <div class=\"relative z-10\" data-kid=\"64\">\n                        <span class=\"text-[10px] font-mono font-bold tracking-[0.3em] text-[#6F00FF] uppercase\" data-kid=\"65\">AI Synthesis</span>\n                        <h3 class=\"text-5xl font-['Space_Grotesk'] font-bold mt-4 tracking-tighter\" id=\"stat-insights\" data-kid=\"66\">8,592</h3>\n                        <p class=\"text-white/60 mt-2 font-medium text-sm\" data-kid=\"67\">Insights Generated</p>\n                        <div class=\"mt-6 h-1 w-full bg-white/5 rounded-full overflow-hidden\" data-kid=\"68\">\n                            <div class=\"h-full bg-[#6F00FF] w-3/4 shadow-[0_0_10px_rgba(111,0,255,0.5)]\" data-kid=\"69\"></div>\n                        </div>\n                    </div>\n                    <div class=\"absolute -right-4 top-1/2 -translate-y-1/2 opacity-5 group-hover:opacity-20 transition-opacity\" data-kid=\"70\">\n                        <i data-lucide=\"brain-circuit\" class=\"w-32 h-32\" data-kid=\"71\"></i>\n                    </div>\n                </div>\n\n                \n                <div class=\"stat-card col-span-12 md:col-span-6 lg:col-span-3 glassmorphism p-8 rounded-3xl relative overflow-hidden group border-l-4 border-l-emerald-500\" data-kid=\"72\">\n                    <div class=\"relative z-10\" data-kid=\"73\">\n                        <span class=\"text-[10px] font-mono font-bold tracking-[0.3em] text-emerald-500 uppercase\" data-kid=\"74\">Model Trust</span>\n                        <div class=\"flex items-baseline gap-1 mt-4\" data-kid=\"75\">\n                            <h3 class=\"text-5xl font-['Space_Grotesk'] font-bold tracking-tighter\" data-kid=\"76\">94</h3>\n                            <span class=\"text-2xl font-bold text-emerald-500/50\" data-kid=\"77\">%</span>\n                        </div>\n                        <p class=\"text-white/60 mt-2 font-medium text-sm\" data-kid=\"78\">Confidence Rating</p>\n                        <div class=\"mt-6 flex gap-1\" data-kid=\"79\">\n                            <div class=\"h-1 w-4 bg-emerald-500 rounded-full\" data-kid=\"80\"></div>\n                            <div class=\"h-1 w-4 bg-emerald-500 rounded-full\" data-kid=\"81\"></div>\n                            <div class=\"h-1 w-4 bg-emerald-500 rounded-full\" data-kid=\"82\"></div>\n                            <div class=\"h-1 w-4 bg-emerald-500/20 rounded-full\" data-kid=\"83\"></div>\n                        </div>\n                    </div>\n                </div>\n            </section>\n\n        \n        <section class=\"px-10 py-6 flex flex-col gap-1\" data-kid=\"84\">\n            <h1 class=\"text-3xl font-['Space_Grotesk'] font-bold tracking-tight\" data-kid=\"85\">Your Projects</h1>\n            <p class=\"text-white/40 text-sm\" data-kid=\"86\">Each project holds its own research documents and AI chat history.</p>\n        </section>\n\n            \n            <section class=\"px-10 pb-20 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-12\" id=\"photo-wall\" data-kid=\"87\">\n                \n                \n                <div class=\"project-card stacked-layer neon-inset glassmorphism rounded-2xl p-8 cursor-pointer group hover:scale-[1.02] active:scale-[0.98]\" data-kid=\"88\">\n                    <div class=\"flex justify-between items-s