      },
      "html": "\n<link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"0\">\n<style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Fira+Sans:wght@300;400;500;600&family=Fira+Code:wght@400;500&display=swap');\n\n    :root {\n        --color-bg: #010B13;\n        --color-navy: #011F5B;\n        --color-indigo: #6F00FF;\n        --color-aqua: #00CCFF;\n        --font-heading: 'Space Grotesk', sans-serif;\n        --font-body: 'Fira Sans', sans-serif;\n        --font-mono: 'Fira Code', monospace;\n    }\n\n    body {\n        background-color: var(--color-bg);\n        color: #F8FAFC;\n        font-family: var(--font-body);\n        margin: 0;\n        overflow-x: clip;\n    }\n\n    /* Custom Scrollbar */\n    ::-webkit-scrollbar {\n        width: 4px;\n    }\n    ::-webkit-scrollbar-track {\n        background: rgba(255, 255, 255, 0.02);\n    }\n    ::-webkit-scrollbar-thumb {\n        background: var(--color-indigo);\n        border-radius: 10px;\n    }\n\n    /* Patterns */\n    .dark-spotlight {\n        background: radial-gradient(circle at 50% 0%, rgba(0, 204, 255, 0.15) 0%, transparent 70%),\n                    radial-gradient(circle at 0% 0%, rgba(111, 0, 255, 0.1) 0%, transparent 50%),\n                    linear-gradient(to bottom, transparent, rgba(1, 11, 19, 0.8));\n    }\n\n    .neon-inset {\n        border: 1.5px solid var(--color-aqua);\n        box-shadow: 0 0 15px rgba(64, 232, 232, 0.2), inset 0 0 30px rgba(64, 232, 232, 0.04);\n    }\n\n    .neon-tube {\n        position: absolute;\n        inset: -2px;\n        background: linear-gradient(90deg, var(--color-indigo), var(--color-aqua));\n        border-radius: inherit;\n        z-index: -1;\n        opacity: 0.2;\n        filter: blur(4px);\n        transition: opacity 0.3s ease;\n    }\n    .group:focus-within .neon-tube {\n        opacity: 1;\n        filter: blur(8px);\n    }\n\n    .glassmorphism {\n        border: 1px solid rgba(255, 255, 255, 0.08);\n        background: rgba(255, 255, 255, 0.05);\n        backdrop-blur: 12px;\n        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);\n    }\n\n    .left-accent {\n        position: absolute;\n        top: 0;\n        bottom: 0;\n        left: 0;\n        width: 4px;\n        background: linear-gradient(180deg, var(--color-indigo), var(--color-aqua));\n        border-radius: 2px;\n    }\n\n    /* Locomotive/Lenis Velocity Distortion */\n    .velocity-item {\n        /* Transitions removed to avoid GSAP conflict */\n    }\n\n    [data-scroll] {\n        opacity: 0;\n        transform: translateY(20px);\n        transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);\n    }\n    [data-scroll].is-inview {\n        opacity: 1;\n        transform: translateY(0);\n        transition-delay: calc(var(--i, 0) * 0.1s);\n    }\n\n    .circuit-bg {\n        background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%236f00ff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4v-4H4v4H0v2h4v4h2v-4h4v-2H6zm30 0v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");\n    }\n</style>\n\n<div class=\"fixed inset-0 z-[-1]\" data-kid=\"2\">\n    <img src=\"https://images.pexels.com/photos/34742154/pexels-photo-34742154.jpeg?auto=compress&cs=tinysrgb&w=1920&q=80\" class=\"w-full h-full object-cover opacity-20 grayscale brightness-50\" alt=\"Background\" decoding=\"async\" loading=\"lazy\" data-kid=\"3\">\n    <div class=\"absolute inset-0 dark-spotlight bg-[#010B13]/80\" data-kid=\"4\"></div>\n</div>\n\n<div class=\"flex h-screen w-full overflow-hidden circuit-bg\" id=\"main-container\" data-kid=\"5\">\n    \n    <aside class=\"w-20 border-r border-white/5 flex flex-col items-center py-8 gap-10 bg-[#010B13]/90 backdrop-blur-xl z-50\" data-kid=\"6\">\n        <div class=\"w-12 h-12 bg-gradient-to-br from-[#6F00FF] to-[#00CCFF] rounded-xl flex items-center justify-center shadow-[0_0_20px_rgba(111,0,255,0.3)] cursor-pointer group hover:scale-105\" data-kid=\"7\">\n            <i data-lucide=\"zap\" class=\"text-white w-6 h-6 group-hover:rotate-12\" data-kid=\"8\"></i>\n        </div>\n        \n        <nav class=\"flex flex-col gap-8\" data-kid=\"9\">\n            <div class=\"group relative flex flex-col items-center\" data-kid=\"10\">\n                <button class=\"nav-btn p-3 rounded-xl text-white/30 hover:text-white hover:bg-white/5\" data-kid=\"11\">\n                    <i data-lucide=\"layout-grid\" class=\"w-6 h-6\" data-kid=\"12\"></i>\n                </button>\n                <span class=\"absolute left-16 px-2 py-1 bg-white/10 text-[10px] rounded opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap\" data-kid=\"13\">DASHBOARD</span>\n            </div>\n            <div class=\"group relative flex flex-col items-center\" data-kid=\"14\">\n                <button class=\"nav-btn p-3 rounded-xl text-[#00CCFF] bg-[#00CCFF]/10\" data-kid=\"15\">\n                    <i data-lucide=\"message-square\" class=\"w-6 h-6\" data-kid=\"16\"></i>\n                </button>\n                <div class=\"absolute left-0 top-1/2 -translate-y-1/2 w-1 h-6 bg-[#00CCFF] rounded-r-full\" data-kid=\"17\"></div>\n            </div>\n            <div class=\"group relative flex flex-col items-center\" data-kid=\"18\">\n                <button class=\"nav-btn p-3 rounded-xl text-white/30 hover:text-white hover:bg-white/5\" data-kid=\"19\">\n                    <i data-lucide=\"library\" class=\"w-6 h-6\" data-kid=\"20\"></i>\n                </button>\n            </div>\n            <div class=\"group relative flex flex-col items-center\" data-kid=\"21\">\n                <button class=\"nav-btn p-3 rounded-xl text-white/30 hover:text-white hover:bg-white/5\" data-kid=\"22\">\n                    <i data-lucide=\"git-branch\" class=\"w-6 h-6\" data-kid=\"23\"></i>\n                </button>\n            </div>\n        </nav>\n\n        <div class=\"mt-auto flex flex-col gap-6 items-center\" data-kid=\"24\">\n            <button class=\"p-3 rounded-xl text-white/30 hover:text-red-400 hover:bg-red-400/5\" data-kid=\"25\">\n                <i data-lucide=\"log-out\" class=\"w-6 h-6\" data-kid=\"26\"></i>\n            </button>\n            <div class=\"w-10 h-10 rounded-full border-2 border-white/10 p-0.5 overflow-hidden ring-2 ring-[#6F00FF]/20\" data-kid=\"27\">\n                <img src=\"https://i.pravatar.cc/100?u=director\" alt=\"Avatar\" class=\"w-full h-full rounded-full object-cover\" data-kid=\"28\">\n            </div>\n        </div>\n    </aside>\n\n    \n    <main class=\"flex-1 flex overflow-hidden\" data-kid=\"29\">\n        \n        \n        <div class=\"flex-[1.4] flex flex-col border-r border-white/5 bg-[#010B13]/40 backdrop-blur-sm relative\" data-kid=\"30\">\n            \n            \n            <header class=\"h-20 border-b border-white/5 flex items-center justify-between px-8 bg-[#010B13]/60 backdrop-blur-2xl z-20\" data-kid=\"31\">\n                <div class=\"flex items-center gap-4\" data-kid=\"32\">\n                    <div class=\"flex flex-col\" data-kid=\"33\">\n                        <div class=\"flex items-center gap-2\" data-kid=\"34\">\n                            <span class=\"text-[10px] font-mono text-[#6F00FF] tracking-widest uppercase\" data-kid=\"35\">TERMINAL_ACTIVE</span>\n                            <div class=\"w-1.5 h-1.5 rounded-full bg-[#00CCFF] animate-pulse\" data-kid=\"36\"></div>\n                        </div>\n                        <h2 class=\"font-['Space_Grotesk'] text-lg font-bold tracking-tight\" data-kid=\"37\">\n                            ScriptIQ <span class=\"text-white/20 mx-1\" data-kid=\"38\">/</span> <span class=\"text-white/80\" data-kid=\"39\">Project_Astra</span>\n                        </h2>\n                    </div>\n                </div>\n                <div class=\"flex items-center gap-6\" data-kid=\"40\">\n                    <div class=\"hidden lg:flex items-center gap-3 bg-white/5 px-4 py-2 rounded-full border border-white/10\" data-kid=\"41\">\n                        <i data-lucide=\"cpu\" class=\"text-[#00CCFF] w-4 h-4\" data-kid=\"42\"></i>\n                        <span class=\"text-[10px] font-mono text-white/60 tracking-wider\" data-kid=\"43\">A.I. QUERIES: 98/100</span>\n                    </div>\n                    <button class=\"p-2.5 rounded-lg hover:bg-white/5 text-white/40 hover:text-white\" data-kid=\"44\">\n                        <i data-lucide=\"share-2\" class=\"w-5 h-5\" data-kid=\"45\"></i>\n                    </button>\n                    <button class=\"p-2.5 rounded-lg bg-[#6F00FF] text-white shadow-[0_0_20px_rgba(111,0,255,0.4)] hover:bg-[#7F1FFF]\" data-kid=\"46\">\n                        <i data-lucide=\"plus\" class=\"w-5 h-5\" data-kid=\"47\"></i>\n                    </button>\n                </div>\n            </header>\n\n            \n            <div class=\"flex-1 overflow-y-auto p-10 space-y-16\" id=\"chat-scroller\" data-kid=\"48\">\n                \n                <div class=\"flex justify-end\" data-scroll style=\"--i: 0\" data-kid=\"49\">\n                    <div class=\"max-w-[70%] bg-[#011F5B] border border-[#6F00FF]/40 p-5 rounded-2xl rounded-tr-none shadow-[0_10px_40px_rgba(111,0,255,0.2)] relative z-10\" data-kid=\"50\">\n                        <p class=\"text-[15px] leading-relaxed font-medium text-white\" data-kid=\"51\">Summarize the key plot points from the document.</p>\n                        <div class=\"absolute -right-[7px] top-[-1px] w-4 h-4 bg-[#011F5B] border-t border-r border-[#6F00FF]/40 rotate-45\" data-kid=\"52\"></div>\n                    </div>\n                </div>\n\n                \n                <div class=\"flex gap-6 items-start\" data-scroll style=\"--i: 1\" data-kid=\"53\">\n                    <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-[#6F00FF] to-[#00CCFF] flex items-center justify-center shrink-0 shadow-[0_0_15px_rgba(111,0,255,0.2)] mt-1\" data-kid=\"54\">\n                        <i data-lucide=\"sparkles\" class=\"text-white w-5 h-5\" data-kid=\"55\"></i>\n                    </div>\n                    <div class=\"flex-1 relative\" data-kid=\"56\">\n                        <div class=\"left-accent\" data-kid=\"57\"></div>\n                        <div class=\"pl-8 space-y-6\" data-kid=\"58\">\n                            <div data-kid=\"59\">\n                                <h3 class=\"text-xs font-['Space_Grotesk'] font-bold text-[#00CCFF] uppercase tracking-[0.3em] mb-4\" data-kid=\"60\">Structural Intelligence Synthesis</h3>\n                                <p class=\"text-white/90 text-sm leading-relaxed mb-6 font-medium\" data-kid=\"61\">The key plot points are:</p>\n                                \n                                <ul class=\"space-y-5\" data-kid=\"62\">\n                                    <li class=\"flex gap-3 group/item\" data-kid=\"63\">\n                                        <div class=\"w-1.5 h-1.5 rounded-full bg-[#6F00FF] mt-2 shrink-0 group-hover:scale-125 transition-transform shadow-[0_0_8px_var(--color-indigo)]\" data-kid=\"64\"></div>\n                                        <div class=\"text-[14px] text-white/80 leading-relaxed\" data-kid=\"65\">\n                                            Hardik, feeling restless and unsettled two years after his degree, is at a bus stand \n                                            <button class=\"citation-btn text-[10px] ml-1.5 px-2 py-0.5 rounded bg-[#011F5B] border border-[#00CCFF]/30 text-[#00CCFF] font-mono hover:bg-[#00CCFF] hover:text-[#010B13] transition-all cursor-pointer uppercase tracking-tighter\" data-kid=\"66\">SOURCE 4</button>\n                                        </div>\n                                    </li>\n                                    <li class=\"flex gap-3 group/item\" data-kid=\"67\">\n                                        <div class=\"w-1.5 h-1.5 rounded-full bg-[#6F00FF] mt-2 shrink-0 group-hover:scale-125 transition-transform shadow-[0_0_8px_var(--color-indigo)]\" data-kid=\"68\"></div>\n                                        <div class=\"text-[14px] text-white/80 leading-relaxed\" data-kid=\"69\">\n                                            He hears a call for \"Bhatkal!\" which deeply affects him, and he runs to catch a bus displaying \"Kundapur - Byndoor - Bhatkal,\" feeling a \"familiar excitement\" and \"forgotten rush\" \n                                            <button class=\"citation-btn text-[10px] ml-1.5 px-2 py-0.5 rounded bg-[#011F5B] border border-[#00CCFF]/30 text-[#00CCFF] font-mono hover:bg-[#00CCFF] hover:text-[#010B13] transition-all cursor-pointer uppercase tracking-tighter\" data-kid=\"70\">SOURCE 4</button>\n                                        </div>\n                                    </li>\n                                    <li class=\"flex gap-3 group/item\" data-kid=\"71\">\n                                        <div class=\"w-1.5 h-1.5 rounded-full bg-[#6F00FF] mt-2 shrink-0 group-hover:scale-125 transition-transform shadow-[0_0_8px_var(--color-indigo)]\" data-kid=\"72\"></div>\n                                        <div class=\"text-[14px] text-white/80 leading-relaxed\" data-kid=\"73\">\n                                            On the bus, Ishani is guarding a seat for him, preventing another woman from taking it \n                                            <button class=\"citation-btn text-[10px] ml-1.5 px-2 py-0.5 rounded bg-[#011F5B] border border-[#00CCFF]/30 text-[#00CCFF] font-mono hover:bg-[#00CCFF] hover:text-[#010B13] transition-all cursor-pointer uppercase tracking-tighter\" data-kid=\"74\">SOURCE 5</button>\n                                        </div>\n                                    </li>\n                                    <li class=\"flex gap-3 group/item\" data-kid=\"75\">\n                                        <div class=\"w-1.5 h-1.5 rounded-full bg-[#6F00FF] mt-2 shrink-0 group-hover:scale-125 transition-transform shadow-[0_0_8px_var(--color-indigo)]\" data-kid=\"76\"></div>\n                                        <div class=\"text-[14px] text-white/80 leading-relaxed\" data-kid=\"77\">\n                                            Hardik arrives and slides into the seat beside her, and they share a moment of quiet relief \n                                            <button class=\"citation-btn text-[10px] ml-1.5 px-2 py-0.5 rounded bg-[#011F5B] border border-[#00CCFF]/30 text-[#00CCFF] font-mono hover:bg-[#00CCFF] hover:text-[#010B13] transition-all cursor-pointer uppercase tracking-tighter\" data-kid=\"78\">SOURCE 5</button>\n                                        </div>\n                                    </li>\n                                    <li class=\"flex gap-3 group/item\" data-kid=\"79\">\n                                        <div class=\"w-1.5 h-1.5 rounded-full bg-[#6F00FF] mt-2 shrink-0 group-hover:scale-125 transition-transform shadow-[0_0_8px_var(--color-indigo)]\" data-kid=\"80\"></div>\n                                        <div class=\"text-[14px] text-white/90 leading-relaxed\" data-kid=\"81\">\n                                            Ishani's \"unguarded smile\" is noted by Hardik as \"unchanged\" despite two years \n                                            <button class=\"citation-btn text-[10px] ml-1.5 px-2 py-0.5 rounded bg-[#011F5B] border border-[#00CCFF]/30 text-[#00CCFF] font-mono hover:bg-[#00CCFF] hover:text-[#010B13] transition-all cursor-pointer uppercase tracking-tighter\" data-kid=\"82\">SOURCE 5</button>\n                                        </div>\n                                    </li>\n                                    <li class=\"flex gap-3 group/item\" data-kid=\"83\">\n                                        <div class=\"w-1.5 h-1.5 rounded-full bg-[#6F00FF] mt-2 shrink-0 group-hover:scale-125 transition-transform shadow-[0_0_8px_var(--color-indigo)]\" data-kid=\"84\"></div>\n                                        <div class=\"text-[14px] text-white/90 leading-relaxed\" data-kid=\"85\">\n                                            Hardik asks Ishani if she \"saved it again,\" referring to his seat, and she confirms she wouldn't let anyone take it \n                                            <button class=\"citation-btn text-[10px] ml-1.5 px-2 py-0.5 rounded bg-[#011F5B] border border-[#00CCFF]/30 text-[#00CCFF] font-mono hover:bg-[#00CCFF] hover:text-[#010B13] transition-all cursor-pointer uppercase tracking-tighter\" data-kid=\"86\">SOURCE 2</button>\n                                        </div>\n                                    </li>\n                                    <li class=\"flex gap-3 group/item\" data-kid=\"87\">\n                                        <div class=\"w-1.5 h-1.5 rounded-full bg-[#6F00FF] mt-2 shrink-0 group-hover:scale-125 transition-transform shadow-[0_0_8px_var(--color-indigo)]\" data-kid=\"88\"></div>\n                                        <div class=\"text-[14px] text-white/90 leading-relaxed\" data-kid=\"89\">\n                                            Hardik's fingers slowly find and interlock with Ishani's hand, which she holds \"Firm. Certain. As if it had always been meant to happen\" \n                                            <button class=\"citation-btn text-[10px] ml-1.5 px-2 py-0.5 rounded bg-[#011F5B] border border-[#00CCFF]/30 text-[#00CCFF] font-mono hover:bg-[#00CCFF] hover:text-[#010B13] transition-all cursor-pointer uppercase tracking-tighter\" data-kid=\"90\">SOURCE 1</button>\n                                        </div>\n                                    </li>\n                                    <li class=\"flex gap-3 group/item\" data-kid=\"91\">\n                                        <div class=\"w-1.5 h-1.5 rounded-full bg-[#6F00FF] mt-2 shrink-0 group-hover:scale-125 transition-transform shadow-[0_0_8px_var(--color-indigo)]\" data-kid=\"92\"></div>\n                                        <div class=\"text-[14px] text-white/90 leading-relaxed\" data-kid=\"93\">\n                                            Ishani leans closer and rests her head on Hardik's shoulder, and he relaxes to hold her comfortably \n                                            <button class=\"citation-btn text-[10px] ml-1.5 px-2 py-0.5 rounded bg-[#011F5B] border border-[#00CCFF]/30 text-[#00CCFF] font-mono hover:bg-[#00CCFF] hover:text-[#010B13] transition-all cursor-pointer uppercase tracking-tighter\" data-kid=\"94\">SOURCE 1</button>\n                                        </div>\n                                    </li>\n                                </ul>\n\n                                \n                                <div class=\"mt-10 flex flex-wrap gap-3 pt-6 border-t border-white/5\" data-kid=\"95\">\n                                    <button class=\"citation-badge flex items-center gap-2 px-3 py-1.5 rounded-lg bg-white/5 border border-white/10 text-[11px] font-mono text-white/40 hover:text-[#00CCFF] hover:border-[#00CCFF]/40 transition-all\" data-kid=\"96\">\n                                        <i class=\"lucide-paperclip text-xs\" data-kid=\"97\"></i> Excerpt-1 DTPP.pdf p.7\n                                    </button>\n                                    <button class=\"citation-badge flex items-center gap-2 px-3 py-1.5 rounded-lg bg-white/5 border border-white/10 text-[11px] font-mono text-white/40 hover:text-[#00CCFF] hover:border-[#00CCFF]/40 transition-all\" data-kid=\"98\">\n                                        <i class=\"lucide-paperclip text-xs\" data-kid=\"99\"></i> Excerpt-1 DTPP.pdf p.6\n                                    </button>\n                                    <button class=\"citation-badge flex items-center gap-2 px-3 py-1.5 rounded-lg bg-[#00CCFF]/10 border border-[#00CCFF]/40 text-[11px] font-mono text-[#00CCFF]\" data-kid=\"100\">\n                                        <i class=\"lucide-paperclip text-xs\" data-kid=\"101\"></i> Excerpt-1 DTPP.pdf p.1\n                                    </button>\n                                    <button class=\"citation-badge flex items-center gap-2 px-3 py-1.5 rounded-lg bg-white/5 border border-white/10 text-[11px] font-mono text-white/40 hover:text-[#00CCFF] hover:border-[#00CCFF]/40 transition-all\" data-kid=\"102\">\n                                        <i class=\"lucide-paperclip text-xs\" data-kid=\"103\"></i> Excerpt-1 DTPP.pdf p.2\n                                    </button>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"p-8 pb-12 bg-[#010B13]/90 backdrop-blur-3xl border-t border-white/5\" data-kid=\"104\">\n                <div class=\"relative group\" data-kid=\"105\">\n                    <div class=\"neon-tube\" data-kid=\"106\"></div>\n                    <div class=\"relative bg-[#011F5B]/80 rounded-2xl border border-white/20 flex items-center p-3 focus-within:border-[#00CCFF]/50 shadow-[inset_0_2px_10px_rgba(0,0,0,0.5)]\" data-kid=\"107\">\n                        <div class=\"px-4 flex items-center gap-3 border-r border-white/10 mr-2\" data-kid=\"108\">\n                            <i data-lucide=\"paperclip\" class=\"text-white/30 w-5 h-5\" data-kid=\"109\"></i>\n                        </div>\n                        <input type=\"text\" placeholder=\"Analyze specific sequence or character arc...\" class=\"w-full bg-transparent px-2 py-3 outline-hidden text-[15px] placeholder:text-white/30 font-medium text-white\" data-kid=\"110\">\n                        <button class=\"bg-[#6F00FF] p-4 rounded-xl shadow-[0_0_20px_rgba(111,0,255,0.3)] flex items-center justify-center\" data-kid=\"111\">\n                            <i data-lucide=\"send\" class=\"text-white w-5 h-5\" data-kid=\"112\"></i>\n                        </button>\n                    </div>\n                </div>\n                <div class=\"mt-4 flex justify-between items-center\" data-kid=\"113\">\n                    <div class=\"flex items-center gap-4\" data-kid=\"114\">\n                        <span class=\"text-[10px] text-white/30 uppercase tracking-[0.2em] font-bold\" data-kid=\"115\">MODE: SCRIPT_EXPERT</span>\n                        <div class=\"flex gap-1\" data-kid=\"116\">\n                            <div class=\"w-1 h-1 rounded-full bg-[#00CCFF]\" data-kid=\"117\"></div>\n                            <div class=\"w-1 h-1 rounded-full bg-[#00CCFF]/40\" data-kid=\"118\"></div>\n                            <div class=\"w-1 h-1 rounded-full bg-[#00CCFF]/20\" data-kid=\"119\"></div>\n                        </div>\n                    </div>\n                    <span class=\"text-[10px] text-white/20 font-mono uppercase tracking-widest\" data-kid=\"120\">Shift + Enter for multi-line analysis</span>\n                </div>\n            </div>\n        </div>\n\n        \n        <div class=\"flex-1 bg-[#011F5B]/20 backdrop-blur-3xl p-8 flex flex-col gap-6 overflow-hidden\" data-kid=\"121\">\n            \n            <div class=\"flex items-center justify-between\" data-kid=\"122\">\n                <div class=\"flex flex-col gap-1\" data-kid=\"123\">\n                    <div class=\"flex items-center gap-2\" data-kid=\"124\">\n                        <i class=\"lucide-file-text text-[#00CCFF] text-lg\" data-kid=\"125\"></i>\n                        <span class=\"text-sm font-bold tracking-tight\" data-kid=\"126\">Excerpt-1 DTPP.pdf</span>\n                    </div>\n                    <span class=\"text-[10px] font-mono text-white/40\" data-kid=\"127\">ID: DOC_BHA_004 // PAGE 1 OF 12</span>\n                </div>\n                <div class=\"flex items-center gap-2\" data-kid=\"128\">\n                    <button class=\"p-2 rounded-lg bg-white/5 hover:bg-white/10 text-white/60 transition-colors\" data-kid=\"129\">\n                        <i class=\"lucide-search text-sm\" data-kid=\"130\"></i>\n                    </button>\n                    <button class=\"p-2 rounded-lg bg-white/5 hover:bg-white/10 text-white/60 transition-colors\" data-kid=\"131\">\n                        <i class=\"lucide-maximize-2 text-sm\" data-kid=\"132\"></i>\n                    </button>\n                </div>\n            </div>\n\n            \n            <div class=\"flex-1 glassmorphism rounded-2xl overflow-hidden flex flex-col relative group\" data-kid=\"133\">\n                \n                <div class=\"absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-[#00CCFF]/30 to-transparent\" data-kid=\"134\"></div>\n                <div class=\"absolute inset-0 border border-white/5 pointer-events-none rounded-2xl\" data-kid=\"135\"></div>\n                \n                <div class=\"h-10 border-b border-white/5 bg-white/5 flex items-center justify-between px-5\" data-kid=\"136\">\n                    <div class=\"flex gap-2\" data-kid=\"137\">\n                        <div class=\"w-2.5 h-2.5 rounded-full bg-red-500/30\" data-kid=\"138\"></div>\n                        <div class=\"w-2.5 h-2.5 rounded-full bg-yellow-500/30\" data-kid=\"139\"></div>\n                        <div class=\"w-2.5 h-2.5 rounded-full bg-green-500/30\" data-kid=\"140\"></div>\n                    </div>\n                    <div class=\"text-[9px] font-mono text-[#00CCFF]/60 uppercase tracking-widest flex items-center gap-2\" data-kid=\"141\">\n                        <i class=\"lucide-eye text-[10px]\" data-kid=\"142\"></i> Live Inspection v2.0\n                    </div>\n                </div>\n\n                \n                <div class=\"flex-1 p-10 overflow-y-auto custom-scrollbar\" id=\"doc-scroller\" data-kid=\"143\">\n                    <div class=\"max-w-2xl mx-auto space-y-10\" data-kid=\"144\">\n                        <div class=\"flex items-center gap-4 opacity-30\" data-kid=\"145\">\n                            <div class=\"h-[1px] flex-1 bg-white/20\" data-kid=\"146\"></div>\n                            <span class=\"text-[10px] font-mono uppercase tracking-[0.4em] text-white\" data-kid=\"147\">Section_Start</span>\n                            <div class=\"h-[1px] flex-1 bg-white/20\" data-kid=\"148\"></div>\n                        </div>\n\n                        <div class=\"space-y-8 text-white/80 font-body italic text-lg leading-relaxed\" data-kid=\"149\">\n                            <p data-kid=\"150\">...The bus stand was a chaos of smells and sounds. Diesel fumes mixed with the scent of wet asphalt and jasmine. Hardik stood there, a ghost in his own life, clutching a degree that felt like a death sentence to his dreams.</p>\n                            \n                            <div class=\"relative py-8 px-10 my-10\" data-kid=\"151\">\n                                <div class=\"absolute inset-0 bg-[#00CCFF]/5 border-l-4 border-[#00CCFF] shadow-[0_0_30px_rgba(0,204,255,0.1)] rounded-r-xl\" data-kid=\"152\"></div>\n                                <div class=\"relative\" data-kid=\"153\">\n                                    <div class=\"flex items-center gap-2 mb-4\" data-kid=\"154\">\n                                        <i class=\"lucide-pin text-[#00CCFF] text-xs\" data-kid=\"155\"></i>\n                                        <span class=\"text-[10px] font-mono text-[#00CCFF] uppercase tracking-widest\" data-kid=\"156\">Cited Text Segment</span>\n                                    </div>\n                                    <p class=\"text-white text-xl leading-relaxed font-medium not-italic\" data-kid=\"157\">\n                                        Suddenly, a voice cut through the noise. \"Bhatkal! Kundapur - Byndoor - Bhatkal!\" It was a jagged cry, but it resonated somewhere deep inside him. He felt a forgotten rush, a familiar excitement that he thought he had buried long ago.\n                                    </p>\n                                </div>\n                                \n                                <svg class=\"absolute -bottom-4 -right-4 w-12 h-12 opacity-40\" viewBox=\"0 0 100 100\" data-kid=\"158\">\n                                    <path d=\"M0,50 L50,50 L50,100\" fill=\"none\" stroke=\"var(--color-aqua)\" stroke-width=\"2\" data-kid=\"159\"></path>\n                                    <circle cx=\"50\" cy=\"100\" r=\"4\" fill=\"var(--color-aqua)\" data-kid=\"160\"></circle>\n                                </svg>\n                            </div>\n\n                            <p data-kid=\"161\">He didn't think. He ran. The heavy bag thumping against his thigh was a rhythmic reminder that he was finally moving towards something, not just away from everything else...</p>\n                        </div>\n\n                        <div class=\"flex items-center gap-4 opacity-40 pt-10\" data-kid=\"162\">\n                            <div class=\"h-[1px] flex-1 bg-white/10\" data-kid=\"163\"></div>\n                            <span class=\"text-[9px] font-mono uppercase tracking-[0.4em]\" data-kid=\"164\">Section_End</span>\n                            <div class=\"h-[1px] flex-1 bg-white/10\" data-kid=\"165\"></div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"h-44 relative mt-auto\" data-kid=\"166\">\n                \n                <div class=\"absolute inset-0 bg-white/[0.02] border border-white/5 rounded-2xl translate-y-4 translate-x-2 backdrop-blur-sm -z-10\" data-kid=\"167\"></div>\n                <div class=\"absolute inset-0 bg-white/[0.04] border border-white/10 rounded-2xl translate-y-2 translate-x-1 backdrop-blur-md -z-5\" data-kid=\"168\"></div>\n                \n                <div class=\"absolute inset-0 bg-[#011F5B]/90 border border-white/20 rounded-2xl p-6 flex flex-col justify-between shadow-2xl\" data-kid=\"169\">\n                    <div class=\"flex items-center justify-between\" data-kid=\"170\">\n                        <div class=\"flex items-center gap-4\" data-kid=\"171\">\n                            <div class=\"w-12 h-12 rounded-xl bg-[#6F00FF]/10 border border-[#6F00FF]/30 flex items-center justify-center\" data-kid=\"172\">\n                                <i data-lucide=\"box\" class=\"text-[#6F00FF] w-6 h-6\" data-kid=\"173\"></i>\n                            </div>\n                            <div data-kid=\"174\">\n                                <h4 class=\"text-xs font-bold uppercase tracking-widest text-[#00CCFF]\" data-kid=\"175\">Project Context</h4>\n                                <p class=\"text-sm font-medium text-white\" data-kid=\"176\">Astra_Script_Master_v2</p>\n                            </div>\n                        </div>\n                        <div class=\"flex -space-x-3\" data-kid=\"177\">\n                            <img src=\"https://i.pravatar.cc/100?u=1\" class=\"w-8 h-8 rounded-full border-2 border-[#011F5B]\" alt=\"user\" data-kid=\"178\">\n                            <img src=\"https://i.pravatar.cc/100?u=2\" class=\"w-8 h-8 rounded-full border-2 border-[#011F5B]\" alt=\"user\" data-kid=\"179\">\n                            <div class=\"w-8 h-8 rounded-full border-2 border-[#011F5B] bg-[#010B13] flex items-center justify-center text-[10px] font-bold text-[#00CCFF]\" data-kid=\"180\">\n                                +3\n                            </div>\n                        </div>\n                    </div>\n                    \n                    <div class=\"flex items-center gap-6 mt-4\" data-kid=\"181\">\n                        <div class=\"flex-1 flex flex-col gap-1\" data-kid=\"182\">\n                            <div class=\"flex justify-between text-[9px] font-mono uppercase tracking-widest opacity-60\" data-kid=\"183\">\n                                <span data-kid=\"184\">Analysis Progress</span>\n                                <span data-kid=\"185\">82%</span>\n                            </div>\n                            <div class=\"h-1.5 w-full bg-white/5 rounded-full overflow-hidden border border-white/5\" data-kid=\"186\">\n                                <div class=\"h-full bg-gradient-to-r from-[#6F00FF] to-[#00CCFF] w-[82%] shadow-[0_0_10px_rgba(0,204,255,0.3)]\" data-kid=\"187\"></div>\n                            </div>\n                        </div>\n                        <button class=\"px-4 py-2 bg-white/5 hover:bg-white/10 rounded-lg text-[10px] font-bold uppercase tracking-widest transition-colors border border-white/10\" data-kid=\"188\">\n                            Details\n                        </button>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </main>\n</div>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"189\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"190\"></script>\n<script src=\"https://unpkg.com/lucide@latest\" data-kid=\"191\"></script>\n<script type=\"module\" data-kid=\"192\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n    import { animate } from 'https://esm.sh/animejs@4';\n\n    // Initialize Icons\n    lucide.createIcons();\n\n    // Initialize Lenis\n    const lenis = new Lenis({\n        duration: 1.2,\n        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n        orientation: 'vertical',\n        gestureOrientation: 'vertical',\n        smoothWheel: true,\n        wheelMultiplier: 1,\n        smoothTouch: false,\n        touchMultiplier: 2,\n        infinite: false,\n    });\n\n    function raf(time) {\n        lenis.raf(time);\n        requestAnimationFrame(raf);\n    }\n    requestAnimationFrame(raf);\n\n    // Locomotive Reveal (Custom Implementation via Lenis + GSAP)\n    gsap.registerPlugin(ScrollTrigger);\n\n    const scrollElements = document.querySelectorAll('[data-scroll]');\n    scrollElements.forEach(el => {\n        ScrollTrigger.create({\n            trigger: el,\n            start: \"top 95%\",\n            onEnter: () => el.classList.add('is-inview'),\n            onLeave: () => el.classList.remove('is-inview'),\n            onEnterBack: () => el.classList.add('is-inview'),\n        });\n    });\n\n    // Velocity Distortion Visual Effect\n    lenis.on('scroll', (e) => {\n        const velocity = Math.abs(e.velocity);\n        const skew = Math.min(velocity * 0.01, 2);\n        const scale = 1 - Math.min(velocity * 0.001, 0.05);\n        \n        document.querySelectorAll('.velocity-item').forEach(item => {\n            gsap.to(item, {\n                skewY: skew,\n                scale: scale,\n                duration: 0.1,\n                ease: \"none\"\n            });\n        });\n    });\n\n    // Anime Hover Color Sweep\n    const btns = document.querySelectorAll('.nav-btn, .citation-badge, .p-2.rounded-lg, .p-4.rounded-xl');\n    btns.forEach(btn => {\n        btn.addEventListener('pointerenter', () => {\n            animate(btn, {\n                scale: 1.05,\n                duration: 400,\n                easing: 'easeOutElastic(1, .8)'\n            });\n        });\n        btn.addEventListener('pointerleave', () => {\n            animate(btn, {\n                scale: 1,\n                duration: 400,\n                easing: 'easeOutElastic(1, .8)'\n            });\n        });\n    });\n\n    // Special sweep for primary buttons\n    const primaryBtn = document.querySelector('.bg-\\\\[\\\\#6F00FF\\\\]');\n    if(primaryBtn) {\n        primaryBtn.addEventListener('pointerenter', () => {\n            animate(primaryBtn, {\n                backgroundColor: '#00CCFF',\n                duration: 300,\n                easing: 'easeOutQuad'\n            });\n        });\n        primaryBtn.addEventListener('pointerleave', () => {\n            animate(primaryBtn, {\n                backgroundColor: '#6F00FF',\n                duration: 300,\n                easing: 'easeOutQuad'\n            });\n        });\n    }\n\n    // Scroll to citation effect\n    document.querySelectorAll('.citation-btn').forEach(btn => {\n        btn.addEventListener('click', () => {\n            const docScroller = document.getElementById('doc-scroller');\n            const target = document.querySelector('.bg-\\\\[\\\\#00CCFF\\\\]\\\\/5');\n            if(target) {\n                docScroller.scrollTo({\n                    top: target.offsetTop - 100,\n                    behavior: 'smooth'\n                });\n                \n                gsap.fromTo(target, \n                    { backgroundColor: \"rgba(0, 204, 255, 0.3)\" }, \n                    { backgroundColor: \"rgba(0, 204, 255, 0.05)\", duration: 1.5 }\n                );\n            }\n        });\n    });\n</script>\n",
