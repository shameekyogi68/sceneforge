      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Fira+Sans:wght@300;400;500;600&family=Fira+Code:wght@400;500&display=swap');\n\n    :root {\n        --color-bg: #010B13;\n        --color-navy: #011F5B;\n        --color-indigo: #6F00FF;\n        --color-aqua: #00CCFF;\n        --color-lilac: #D4C4FB; /* Adjusted to match original screenshot better */\n        --font-heading: 'Space Grotesk', sans-serif;\n        --font-body: 'Fira Sans', sans-serif;\n        --font-mono: 'Fira Code', monospace;\n    }\n\n    body {\n        margin: 0;\n        background-color: var(--color-bg);\n        color: #F8FAFC;\n        font-family: var(--font-body);\n        overflow: hidden;\n    }\n\n    /* Patterns & Effects */\n    .dark-spotlight {\n        background: radial-gradient(circle at 50% 50%, rgba(0, 204, 255, 0.1) 0%, transparent 65%),\n                    radial-gradient(circle at 50% 10%, rgba(111, 0, 255, 0.12) 0%, transparent 70%),\n                    linear-gradient(to bottom, transparent, rgba(1, 11, 19, 0.95));\n    }\n\n    .neon-inset {\n        border: 1px solid rgba(0, 204, 255, 0.4);\n        box-shadow: 0 0 40px rgba(0, 204, 255, 0.1), inset 0 0 20px rgba(0, 204, 255, 0.05);\n    }\n\n    .glow-neon {\n        box-shadow: 0 0 20px rgba(111, 0, 255, 0.3), 0 0 40px rgba(0, 204, 255, 0.2);\n    }\n\n    .circuit-bg {\n        background-image: url(\"data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%236f00ff' fill-opacity='0.04'%3E%3Cpath d='M40 40v-5h-2v5h-5v2h5v5h2v-5h5v-2h-5zM10 40v-5H8v5H3v2h5v5h2v-5h5v-2h-5zM10 10v-5H8v5H3v2h5v5h2v-5h5v-2h-5zm30 0v-5h-2v5h-5v2h5v5h2v-5h5v-2h-5z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");\n    }\n\n    .grid-pattern {\n        background-size: 40px 40px;\n        background-image: linear-gradient(to right, rgba(255, 255, 255, 0.02) 1px, transparent 1px),\n                          linear-gradient(to bottom, rgba(255, 255, 255, 0.02) 1px, transparent 1px);\n    }\n\n    .glass-card {\n        background: rgba(1, 11, 19, 0.75);\n        backdrop-blur: 24px;\n        border: 1px solid rgba(255, 255, 255, 0.08);\n    }\n\n    .text-glow {\n        text-shadow: 0 0 10px rgba(181, 154, 255, 0.4);\n    }\n\n    .btn-glow-pulse {\n        animation: glowPulse 3s infinite alternate;\n    }\n\n    @keyframes glowPulse {\n        from { box-shadow: 0 0 15px rgba(111, 0, 255, 0.3), 0 0 30px rgba(0, 204, 255, 0.15); }\n        to { box-shadow: 0 0 25px rgba(111, 0, 255, 0.6), 0 0 50px rgba(0, 204, 255, 0.35); }\n    }\n</style>\n\n<div class=\"relative min-h-screen w-full flex flex-col items-center justify-center overflow-hidden\" data-kid=\"1\">\n    \n    <div class=\"absolute inset-0 z-[-2]\" data-kid=\"2\">\n        <img src=\"https://images.pexels.com/photos/34742154/pexels-photo-34742154.jpeg?auto=compress&cs=tinysrgb&w=1920&q=80\" class=\"w-full h-full object-cover opacity-25 grayscale brightness-50 contrast-125\" alt=\"Cyber Background\" decoding=\"async\" loading=\"lazy\" data-kid=\"3\">\n    </div>\n    <div class=\"absolute inset-0 z-[-1] dark-spotlight\" data-kid=\"4\"></div>\n    <div class=\"absolute inset-0 z-[-1] circuit-bg opacity-50\" data-kid=\"5\"></div>\n    <div class=\"absolute inset-0 z-[-1] grid-pattern\" data-kid=\"6\"></div>\n\n    \n    <main id=\"login-container\" class=\"relative z-10 w-full max-w-lg px-6\" data-kid=\"7\">\n        <div class=\"glass-card neon-inset rounded-[2.5rem] p-12 lg:py-14 lg:px-16 flex flex-col items-center text-center\" data-kid=\"8\">\n            \n            \n            <header class=\"mb-14 flex flex-col items-center gap-5\" data-kid=\"9\">\n                <div id=\"logo-icon\" class=\"w-24 h-24 bg-gradient-to-br from-[var(--color-indigo)] to-[var(--color-aqua)] rounded-3xl flex items-center justify-center shadow-[0_0_40px_rgba(111,0,255,0.3)] mb-2 group relative\" data-kid=\"10\">\n                    <div class=\"absolute inset-0 bg-white/10 rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"11\"></div>\n                    <svg class=\"w-12 h-12 text-white fill-white transform group-hover:scale-110 transition-transform duration-500\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\" data-kid=\"12\">\n                        <path d=\"M13 10V3L4 14h7v7l9-11h-7z\" data-kid=\"13\"></path>\n                    </svg>\n                </div>\n                <div data-kid=\"14\">\n                    <h1 class=\"text-5xl lg:text-6xl font-bold font-['Space_Grotesk'] tracking-tighter text-[var(--color-lilac)] text-glow mb-2\" data-kid=\"15\">ScriptIQ</h1>\n                    <p class=\"text-white/60 text-sm font-medium tracking-wide\" data-kid=\"16\">Film research, powered by AI</p>\n                </div>\n            </header>\n\n            \n            <div class=\"w-full space-y-10\" data-kid=\"17\">\n                <button id=\"google-auth\" class=\"glow-neon btn-glow-pulse w-full bg-white text-[var(--color-bg)] py-4 px-8 rounded-full font-bold text-lg flex items-center justify-center gap-4 active:scale-[0.98] group cursor-pointer shadow-[0_0_20px_rgba(255,255,255,0.2)]\" data-kid=\"18\">\n                    <img src=\"https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg\" class=\"w-5 h-5\" alt=\"Google\" data-kid=\"19\">\n                    <span class=\"text-slate-900 tracking-tight\" data-kid=\"20\">Continue with Google</span>\n                </button>\n                \n                <div class=\"flex items-center justify-center gap-4 opacity-50\" data-kid=\"21\">\n                    <div class=\"h-[1px] w-14 bg-white/20\" data-kid=\"22\"></div>\n                    <span class=\"text-[9px] font-mono tracking-[0.3em] uppercase text-white/60\" data-kid=\"23\">Encryption Enabled</span>\n                    <div class=\"h-[1px] w-14 bg-white/20\" data-kid=\"24\"></div>\n                </div>\n            </div>\n\n            \n            <footer class=\"mt-12 flex flex-col items-center gap-8\" data-kid=\"25\">\n                <div class=\"flex flex-col items-center gap-3\" data-kid=\"26\">\n                    <p class=\"text-[10px] text-white/40 font-['Fira_Code'] uppercase tracking-[0.4em]\" data-kid=\"27\">Auth System Protocol 7.1 // SECURE</p>\n                    <div class=\"flex gap-1.5\" data-kid=\"28\">\n                        <div class=\"w-1 h-1 rounded-full bg-[var(--color-aqua)] animate-pulse\" data-kid=\"29\"></div>\n                        <div class=\"w-1 h-1 rounded-full bg-[var(--color-aqua)]/60 animate-pulse [animation-delay:200ms]\" data-kid=\"30\"></div>\n                        <div class=\"w-1 h-1 rounded-full bg-[var(--color-aqua)]/30 animate-pulse [animation-delay:400ms]\" data-kid=\"31\"></div>\n                    </div>\n                </div>\n                \n                <p class=\"text-[11px] font-medium text-white/40 tracking-wider max-w-sm text-center leading-relaxed\" data-kid=\"32\">\n                    By signing in you agree to ScriptIQ's \n                    <a href=\"#\" class=\"text-white/70 hover:text-[var(--color-aqua)] transition-colors underline decoration-white/30 underline-offset-4\" data-kid=\"33\">Terms</a> \n                    & \n                    <a href=\"#\" class=\"text-white/70 hover:text-[var(--color-aqua)] transition-colors underline decoration-white/30 underline-offset-4\" data-kid=\"34\">Privacy Policy</a>\n                </p>\n            </footer>\n        </div>\n    </main>\n\n    \n    <div class=\"absolute top-10 left-10 hidden xl:flex items-center gap-3 opacity-40\" data-kid=\"35\">\n        <div class=\"p-2 border border-white/10 rounded-lg bg-white/5\" data-kid=\"36\">\n            <svg class=\"w-4 h-4 text-[var(--color-aqua)]\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" data-kid=\"37\"><path d=\"M12 2v20M2 12h20\" stroke-width=\"2\" data-kid=\"38\"></path></svg>\n        </div>\n        <span class=\"text-[10px] font-mono text-white tracking-[0.3em] uppercase\" data-kid=\"39\">Auth_Terminal_01</span>\n    </div>\n\n    <div class=\"absolute top-10 right-10 hidden xl:flex items-center gap-4 opacity-40\" data-kid=\"40\">\n        <div class=\"text-right\" data-kid=\"41\">\n            <p class=\"text-[10px] font-mono text-white tracking-[0.2em] uppercase leading-none mb-1\" data-kid=\"42\">Status: Operational</p>\n            <p id=\"current-time\" class=\"text-[10px] font-mono text-[var(--color-aqua)] tracking-[0.1em] uppercase leading-none\" data-kid=\"43\">00:00:00 UTC</p>\n        </div>\n        <div class=\"w-10 h-10 border-2 border-white/10 rounded-full flex items-center justify-center\" data-kid=\"44\">\n            <div class=\"w-2 h-2 rounded-full bg-[var(--color-aqua)]\" data-kid=\"45\"></div>\n        </div>\n    </div>\n\n    <div class=\"absolute bottom-10 left-10 hidden xl:block opacity-30\" data-kid=\"46\">\n        <p class=\"text-[9px] font-mono text-white tracking-[0.4em] uppercase\" data-kid=\"47\">Processing Core: ScriptIQ-v4</p>\n    </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"48\"></script>\n<script type=\"module\" data-kid=\"49\">\n    import { animate } from 'https://cdn.jsdelivr.net/npm/motion@12/+esm';\n\n    // GSAP Entrance\n    gsap.from(\"#login-container\", {\n        y: 40,\n        opacity: 0,\n        duration: 1.2,\n        ease: \"power4.out\",\n        delay: 0.2\n    });\n\n    gsap.from(\"#logo-icon\", {\n        scale: 0.5,\n        opacity: 0,\n        duration: 1,\n        ease: \"back.out(1.7)\",\n        delay: 0.6\n    });\n\n    // Time Update\n    function updateTime() {\n        const now = new Date();\n        const timeStr = now.toISOString().split('T')[1].split('.')[0] + ' UTC';\n        const timeEl = document.getElementById('current-time');\n        if (timeEl) timeEl.textContent = timeStr;\n    }\n    setInterval(updateTime, 1000);\n    updateTime();\n\n    // Motion Hover on Google Button\n    const googleBtn = document.getElementById('google-auth');\n    if (googleBtn) {\n        googleBtn.addEventListener('mouseenter', () => {\n            animate(googleBtn, { scale: 1.04 }, { duration: 0.4, type: \"spring\", stiffness: 300 });\n        });\n        googleBtn.addEventListener('mouseleave', () => {\n            animate(googleBtn, { scale: 1 }, { duration: 0.4, type: \"spring\", stiffness: 300 });\n        });\n    }\n\n    // Subtle background movement\n    document.addEventListener('mousemove', (e) => {\n        const x = (e.clientX / window.innerWidth - 0.5) * 20;\n        const y = (e.clientY / window.innerHeight - 0.5) * 20;\n        gsap.to(\"img\", {\n            x: x,\n            y: y,\n            duration: 2,\n            ease: \"power2.out\"\n        });\n    });\n</script>\n",
